    "e01_n01": {
      "id": "e01_n01",
      "speaker": "HALE",
      "events": [
        {
          "type": "systemAlert",
          "text": "[UNKNOWN RELAY SIGNAL DETECTED]",
          "pauseAfterMs": 1000,
          "textKey": "episode_01.e01_n01.event0.text"
        },
        {
          "type": "typing",
          "duration": 1800
        },
        {
          "type": "message",
          "text": "Can you hear me?",
          "textKey": "episode_01.e01_n01.event1.text"
        },
        {
          "type": "pause",
          "duration": 1200
        },
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "Please don't be another automated relay echo. I have been losing arguments with machines for weeks.",
          "textKey": "episode_01.e01_n01.event2.text"
        },
        {
          "type": "typing",
          "duration": 1800
        },
        {
          "type": "message",
          "text": "Wait.",
          "textKey": "episode_01.e01_n01.event3.text"
        },
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "You answered.",
          "textKey": "episode_01.e01_n01.event4.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "Okay. That's real. You're real.",
          "textKey": "episode_01.e01_n01.event5.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "I'm Dr. Ethan Hale. Chief Engineer, Orbital Research Station ECHO.",
          "textKey": "episode_01.e01_n01.event6.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "And before you ask, no, my official emergency plan was not supposed to be begging a stranger through a half-dead relay.",
          "textKey": "episode_01.e01_n01.event7.text"
        }
      ],
      "choices": [
        {
          "id": "who_are_you",
          "text": "WHO ARE YOU?",
          "effects": {
            "trust": 3,
            "morale": 1,
            "haleTrust": 2
          },
          "nextNodeId": "e01_n02_who",
          "textKey": "episode_01.e01_n01.choice0.text"
        },
        {
          "id": "prove_real",
          "text": "PROVE YOU'RE REAL.",
          "effects": {
            "trust": -4,
            "danger": 2,
            "signalStrength": -3,
            "haleTrust": -3
          },
          "nextNodeId": "e01_n02_prove",
          "textKey": "episode_01.e01_n01.choice1.text"
        }
      ]
