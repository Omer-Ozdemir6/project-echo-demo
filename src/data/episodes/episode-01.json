          "fileType": "log",
          "title": "CREW LOG: ETHAN HALE",
          "source": "STATION_ARCHIVE",
          "content": "DR. ETHAN HALE — CHIEF ENGINEER. RELAY MAINTENANCE AUTHORIZATION: 7391. STATUS: ACTIVE.\n\nNOTE: Secondary maintenance index lists deprecated authorization fragment 7319. Use latest active relay authorization only.",
          "caption": "Recovered identity and maintenance fragment.",
          "tags": [
            "crew",
            "hale",
            "relay",
            "code"
          ],
          "message": "[CREW LOG ARCHIVED TO DATA BANK]",
          "pauseAfterMs": 1300,
          "titleKey": "episode_01.e01_n03.event4.title",
          "contentKey": "episode_01.e01_n03.event4.content",
          "captionKey": "episode_01.e01_n03.event4.caption",
          "messageKey": "episode_01.e01_n03.event4.message"
        },
        {
          "type": "typing",
          "duration": 2700
        },
        {
          "type": "message",
          "text": "That maintenance code may still open the relay door. The current one. Not the deprecated one.",
          "textKey": "episode_01.e01_n03.event6.text"
        },
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "And yes, I realize I just sent you a file with my authorization code in it.",
          "textKey": "episode_01.e01_n03.event8.text"
        },
        {
          "type": "typing",
          "duration": 1800
        },
        {
          "type": "message",
          "text": "Please don't make that the most embarrassing thing that happens today.",
          "textKey": "episode_01.e01_n03.event10.text"
        },
        {
          "type": "backgroundEvent",
          "delay": 9000,
          "event": {
            "type": "systemAlert",
            "text": "[BACKGROUND SCAN: WEAK SECONDARY SIGNAL DETECTED]",
            "textKey": "episode_01.e01_n03.backgroundEvent11.text"
          }
        }
      ],
      "choices": [
