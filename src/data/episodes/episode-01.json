    "e01_n02_who": {
      "id": "e01_n02_who",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "Right. Names first. Panic second.",
          "textKey": "episode_01.e01_n02_who.event0.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "I kept the relay spine alive after the blackout. Which sounds heroic until you remember the relay is currently coughing blood.",
          "textKey": "episode_01.e01_n02_who.event1.text"
        }
      ],
      "nextNodeId": "e01_n02"
    },
    "e01_n02_prove": {
      "id": "e01_n02_prove",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "Seriously?",
          "textKey": "episode_01.e01_n02_prove.event0.text"
        },
        {
          "type": "typing",
          "duration": 2800
        },
        {
          "type": "message",
          "text": "No. That's fair. Annoying, but fair.",
