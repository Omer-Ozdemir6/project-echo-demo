        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "You're the first signal I've had in months that didn't sound like a ghost wearing someone else's mouth.",
          "textKey": "episode_01.e01_n02.event2.text"
        },
        {
          "type": "backgroundEvent",
          "delay": 6000,
          "event": {
