  "nodes": {
    "e01_n01": {
      "id": "e01_n01",
      "speaker": "HALE",
      "events": [
        {
          "type": "systemAlert",
          "text": "[UNKNOWN RELAY SIGNAL DETECTED]",
          "pauseAfterMs": 1000,
          "textKey": "episode_01.e01_n01.event0.text"
        },
        {
          "type": "typing",
          "duration": 1800
        },
        {
          "type": "message",
          "text": "Can you hear me?",
          "textKey": "episode_01.e01_n01.event2.text"
        },
        {
          "type": "pause",
          "duration": 1500
        },
        {
          "type": "typing",
          "duration": 1700
        },
        {
          "type": "message",
          "text": "If this is another automated relay echo, I swear I'm going to lose what little patience I have left.",
          "textKey": "episode_01.e01_n01.event5.text"
        },
        {
          "type": "pause",
          "duration": 1200
        },
        {
          "type": "typing",
          "duration": 1500
        },
        {
          "type": "message",
          "text": "Wait...",
          "textKey": "episode_01.e01_n01.event8.text"
        },
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "You answered.",
          "textKey": "episode_01.e01_n01.event10.text"
        },
        {
          "type": "typing",
          "duration": 2500
        },
        {
          "type": "message",
          "text": "Okay. Okay, that's real. You're real.",
          "textKey": "episode_01.e01_n01.event12.text"
        },
        {
          "type": "typing",
          "duration": 2800
        },
        {
          "type": "message",
          "text": "My name is Dr. Ethan Hale.",
          "textKey": "episode_01.e01_n01.event14.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Chief Engineer. Orbital Research Station ECHO. And before you ask, no, I don't have a better distress protocol than begging a stranger through a broken relay.",
          "textKey": "episode_01.e01_n01.event16.text"
        }
      ],
      "choices": [
        {
          "id": "who_are_you",
          "text": "WHO ARE YOU?",
          "effects": {
            "trust": 3,
            "morale": 1
          },
          "nextNodeId": "e01_n02_who",
          "textKey": "episode_01.e01_n01.choice0.text"
        },
        {
          "id": "prove_real",
          "text": "PROVE YOU'RE REAL.",
          "effects": {
            "trust": -4,
            "danger": 2,
            "signalStrength": -3
          },
          "nextNodeId": "e01_n02_prove",
          "textKey": "episode_01.e01_n01.choice1.text"
        }
      ]
    },
    "e01_n02_who": {
      "id": "e01_n02_who",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "Right. Names first. Panic second.",
          "textKey": "episode_01.e01_n02_who.event0.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "I'm Hale. Engineering lead. I kept the relay spine alive after the blackout.",
          "textKey": "episode_01.e01_n02_who.event1.text"
        },
        {
          "type": "typing",
          "duration": 2900
        },
        {
          "type": "message",
          "text": "That sounds impressive until you remember I'm currently talking to you through a dying antenna and a prayer.",
          "textKey": "episode_01.e01_n02_who.event2.text"
        }
      ],
      "nextNodeId": "e01_n02"
    },
    "e01_n02_prove": {
      "id": "e01_n02_prove",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "Seriously?",
          "textKey": "episode_01.e01_n02_prove.event0.text"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 2700
        },
        {
          "type": "message",
          "text": "No. That's fair. Annoying, but fair.",
          "textKey": "episode_01.e01_n02_prove.event1.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "I have oxygen at thirty-two percent, a suit battery that keeps lying to me, and a station that answers back in voices it shouldn't have.",
          "textKey": "episode_01.e01_n02_prove.event2.text"
        },
        {
          "type": "systemAlert",
          "text": "[BIOMETRIC FRAGMENT ATTACHED]",
          "pauseAfterMs": 900,
          "textKey": "episode_01.e01_n02_prove.event3.text"
        },
        {
          "type": "statChange",
          "changes": {
            "signalStrength": -4
          }
        }
      ],
      "nextNodeId": "e01_n02"
    },
    "e01_n02": {
      "id": "e01_n02",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "The station suffered a major systems failure.",
          "textKey": "episode_01.e01_n02.event5.text"
        },
        {
          "type": "typing",
          "duration": 2800
        },
        {
          "type": "message",
          "text": "Most communication channels collapsed. Internal routing is fragmented. External traffic is basically dead.",
          "textKey": "episode_01.e01_n02.event7.text"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "You're the first real signal I've received in months.",
          "textKey": "episode_01.e01_n02.event10.text"
        },
        {
          "type": "backgroundEvent",
          "delay": 6000,
          "event": {
            "type": "systemAlert",
            "text": "[UNAUTHORIZED OBSERVER DETECTED]",
            "textKey": "episode_01.e01_n02.backgroundEvent11.text"
          }
        }
      ],
      "choices": [
        {
          "id": "i_can_help",
          "text": "I CAN HELP.",
          "effects": {
            "trust": 5,
            "morale": 5,
            "signalStrength": 2
          },
          "nextNodeId": "e01_n03_help",
          "textKey": "episode_01.e01_n02.choice0.text"
        },
        {
          "id": "need_more_info",
          "text": "I NEED MORE INFORMATION.",
          "effects": {
            "trust": 1,
            "danger": -1
          },
          "nextNodeId": "e01_n03_info",
          "textKey": "episode_01.e01_n02.choice1.text"
        }
      ]
    },
    "e01_n03_help": {
      "id": "e01_n03_help",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "Good. I needed to hear that more than I want to admit.",
          "textKey": "episode_01.e01_n03_help.event0.text"
        },
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "Stay sharp, though. Helping me may not mean trusting me.",
          "textKey": "episode_01.e01_n03_help.event1.text"
        }
      ],
      "nextNodeId": "e01_n03"
    },
    "e01_n03_info": {
      "id": "e01_n03_info",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2500
        },
        {
          "type": "message",
          "text": "Smart. Slower, but smart.",
          "textKey": "episode_01.e01_n03_info.event0.text"
        },
        {
          "type": "typing",
          "duration": 2900
        },
        {
          "type": "message",
          "text": "Ask questions. Just don't take forever. The station isn't waiting for us to become friends.",
          "textKey": "episode_01.e01_n03_info.event1.text"
        }
      ],
      "nextNodeId": "e01_n03"
    },
    "e01_n03": {
      "id": "e01_n03",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "Information is something I can still give you.",
          "textKey": "episode_01.e01_n03.event1.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "I'm sending the only crew record I can still access. If it cuts out halfway, don't blame me. Blame the relay. Or the corpse of the relay.",
          "textKey": "episode_01.e01_n03.event3.text"
        },
