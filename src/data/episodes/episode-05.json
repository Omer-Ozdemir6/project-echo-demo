        {
          "type": "systemAlert",
          "text": "[IMAGE ANALYSIS: DETECTED PERSONNEL: 7]",
          "textKey": "episode_05.e05_n06.event2.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "speaker": "MAYA",
          "text": "Exactly. That's impossible.",
          "textKey": "episode_05.e05_n06.event3.text"
        },
        {
          "type": "typing",
          "duration": 4000
        },
        {
          "type": "message",
          "speaker": "MAYA",
          "text": "Six bunks. Six suits. Six emergency tags.",
          "textKey": "episode_05.e05_n06.event4.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "speaker": "MAYA",
          "text": "We don't bring extras.",
          "textKey": "episode_05.e05_n06.event5.text"
        },
        {
          "type": "statChange",
          "changes": {
            "danger": 4,
            "morale": -2,
            "signalStrength": -3
          }
        }
      ],
      "choices": [
        {
          "id": "scan_manifest_layer",
          "text": "SCAN MANIFEST LAYER.",
          "effects": {
            "danger": 2,
            "signalStrength": -2
          },
          "nextNodeId": "e05_n08",
          "textKey": "episode_05.e05_n06.choice0.text"
        },
        {
          "id": "ask_if_maya_knows",
          "text": "DO YOU KNOW WHO IT IS?",
          "effects": {
            "mayaTrust": -1,
            "danger": 2
          },
          "nextNodeId": "e05_n07_maya",
          "textKey": "episode_05.e05_n06.choice1.text"
        }
      ]
    },
    "e05_n07_maya": {
      "id": "e05_n07_maya",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "No.",
          "textKey": "episode_05.e05_n07_maya.event0.text"
        },
        {
          "type": "typing",
          "duration": 4400
        },
        {
          "type": "message",
          "text": "And I know how convenient that sounds.",
          "textKey": "episode_05.e05_n07_maya.event1.text"
        },
        {
          "type": "typing",
          "duration": 4600
        },
        {
          "type": "message",
          "text": "But if there was a seventh person on ECHO, someone worked very hard to make us forget them.",
          "textKey": "episode_05.e05_n07_maya.event2.text"
        }
      ],
      "nextNodeId": "e05_n08"
    },
