{
  "id": "episode_05",
  "title": "THE SIX — OPERATION CUT V2",
  "startNodeId": "e05_n01",
  "puzzles": {},
  "nodes": {
    "e05_n01": {
      "id": "e05_n01",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2500
        },
        {
          "type": "message",
          "text": "If we're going to survive, you need to know who we were.",
          "textKey": "episode_05.e05_n01.event1.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Not as a list. Lists are what the station keeps after it has already failed the people on them.",
          "textKey": "episode_05.e05_n01.event3.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "I'm leaving the damaged relay console. Life support has an old personnel index near the lower access spine.",
          "textKey": "episode_05.e05_n01.event5.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "If the seventh person was erased, the systems around them may still remember the shape of the hole.",
          "textKey": "episode_05.e05_n01.event7.text"
        },
        {
          "type": "progressTask",
          "id": "maya_pack_relay",
          "title": "MAYA SECURING PORTABLE RELAY",
          "subtitle": "Preparing to move from relay console to lower access spine",
          "duration": 5000,
          "completeText": "Maya is mobile.",
          "tone": "character",
          "titleKey": "episode_05.e05_n01.event8.title",
          "completeTextKey": "episode_05.e05_n01.event8.completeText"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Okay. Relay pack is ugly, hot, and probably judging me. We're moving.",
          "textKey": "episode_05.e05_n01.event10.text"
        }
      ],
      "choices": [
        {
          "id": "pull_manifest_remote",
          "text": "PULL THE OFFICIAL MANIFEST WHILE SHE MOVES.",
          "effects": {},
          "nextNodeId": "e05_n02_manifest",
          "nextEpisodeId": {
            "signalStrength": 1,
            "mayaTrust": 1
          },
          "textKey": "episode_05.e05_n01.choice0.text"
        },
        {
          "id": "ask_maya_memory",
          "text": "ASK MAYA WHO THE CREW REALLY WERE.",
          "effects": {},
          "nextNodeId": "e05_n02_memory",
          "nextEpisodeId": {
            "mayaTrust": 3,
            "morale": -1
          },
          "textKey": "episode_05.e05_n01.choice1.text"
        }
      ],
      "directorNotes": {
        "objective": "Guide Maya from the damaged relay console toward life-support records and expose the erased seventh crew member."
      }
    },
    "e05_n02_memory": {
      "id": "e05_n02_memory",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Cruel question. Fair question.",
          "textKey": "episode_05.e05_n02_memory.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Grant handled security. He called himself Head of Not Dying, which was annoying because he was usually right.",
          "textKey": "episode_05.e05_n02_memory.event3.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Rivera solved problems before you finished explaining them. It made you grateful and furious at the same time.",
          "textKey": "episode_05.e05_n02_memory.event5.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "Park joked when he was scared. Owens pretended not to laugh, then fixed his coffee ratio when he wasn't looking.",
          "textKey": "episode_05.e05_n02_memory.event7.text"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Hale pretended he didn't need anyone.",
          "textKey": "episode_05.e05_n02_memory.event10.text"
        },
        {
          "type": "typing",
          "duration": 3300
        },
        {
          "type": "message",
          "text": "Worst liar on the station.",
          "textKey": "episode_05.e05_n02_memory.event12.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "That's what hurts. ECHO didn't erase strangers. It erased people with bad jokes, favorite mugs, unfinished arguments.",
          "textKey": "episode_05.e05_n02_memory.event14.text"
        },
        {
          "type": "backgroundEvent",
          "delay": 6000,
          "event": {
            "type": "message",
            "speaker": "MAYA",
            "text": "Left turn ahead. The deck plating is bowed here. I'm stepping around it.",
            "textKey": "episode_05.e05_n02_memory.backgroundEvent15.text"
          }
        }
      ],
      "nextNodeId": "e05_n02_manifest"
    },
    "e05_n02_manifest": {
