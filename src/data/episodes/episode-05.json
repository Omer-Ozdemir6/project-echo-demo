        },
        {
          "type": "log",
          "id": "suit_registry_01",
          "fileId": "suit_registry_01",
          "fileType": "log",
          "title": "SUIT REGISTRY",
          "content": "ECHO EVA SUIT REGISTRY\n\nSUIT-01: ETHAN HALE\nSUIT-02: MAYA CHEN\nSUIT-03: GRANT WALKER\nSUIT-04: RIVERA TORRES\nSUIT-05: OWEN PARK\nSUIT-06: SARAH OWENS\nSUIT-07: ENTRY ERASED\n\nRegistry repair failed.",
          "caption": "Recovered EVA suit registry. Seventh suit slot exists but identity is erased.",
          "source": "EVA_STORAGE",
          "tags": [
            "suit",
            "registry",
            "crew",
            "erased"
          ],
          "correlationTags": [
            "seventh_person"
          ],
          "message": "[SUIT REGISTRY ARCHIVED TO DATA BANK]",
          "pauseAfterMs": 1200,
          "titleKey": "episode_05.e05_n04.event2.title",
          "contentKey": "episode_05.e05_n04.event2.content",
          "captionKey": "episode_05.e05_n04.event2.caption",
          "messageKey": "episode_05.e05_n04.event2.message"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "Seven biometric loads.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event12.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "That doesn't mean seven names.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event14.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That's the kind of sentence people say when they want to feel safe and technical.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event16.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "But life support doesn't care about names.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event18.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "It counts bodies.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event20.text"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "And the suits counted one more than we did.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n04.event23.text"
        }
      ],
      "nextNodeId": "e05_n05"
    },
    "e05_n05": {
      "id": "e05_n05",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "No photo. No face. No neat little proof you can stare at until it makes sense.",
          "textKey": "episode_05.e05_n05.event0.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Just systems disagreeing with each other. That's worse, honestly.",
          "textKey": "episode_05.e05_n05.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Systems don't panic. They don't hallucinate. They just record the wrong truth.",
          "textKey": "episode_05.e05_n05.event2.text"
        },
        {
          "type": "pause",
          "duration": 800
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "I almost wish we'd found a body.",
          "textKey": "episode_05.e05_n05.event8.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Bodies are simple. Records are not.",
          "textKey": "episode_05.e05_n05.event10.text"
        },
        {
          "type": "typing",
          "duration": 4000
        },
        {
          "type": "message",
