    "e05_n09_accuse": {
      "id": "e05_n09_accuse",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "There it is.",
          "textKey": "episode_05.e05_n09_accuse.event0.text"
        },
        {
          "type": "typing",
          "duration": 4600
        },
        {
          "type": "message",
          "text": "One whisper from the dark and suddenly I'm the suspect.",
          "textKey": "episode_05.e05_n09_accuse.event1.text"
        },
        {
          "type": "typing",
          "duration": 5200
        },
        {
          "type": "message",
          "text": "Fine. Keep that question. Just don't let it stop you from asking the right one.",
          "textKey": "episode_05.e05_n09_accuse.event2.text"
        },
