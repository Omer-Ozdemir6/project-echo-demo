    "e05_n03": {
      "id": "e05_n03",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Grant handled security."
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "He called himself Head of Not Dying."
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Rivera managed logistics. If something moved on this station, Rivera knew where it came from, where it was going, and who was about to complain about it."
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Park and Owens maintained the lower sectors."
        },
        {
          "type": "pause",
          "duration": 1000
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "Nobody liked the lower sectors."
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Park pretended he did. Owens called him a liar every morning."
        }
      ],
      "choices": [
        {
          "id": "continue_team",
          "text": "CONTINUE.",
          "nextNodeId": "e05_n04"
        }
      ]
    },
    "e05_n04": {
