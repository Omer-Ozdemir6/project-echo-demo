    "e05_n01_maya_memory": {
      "id": "e05_n01_maya_memory",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "Grant acted like everything was a security drill. Rivera solved problems before anyone finished explaining them.",
          "textKey": "episode_05.e05_n01_maya_memory.event0.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Park made jokes when he was scared. Owens pretended not to laugh. Hale pretended he didn't need anyone.",
          "textKey": "episode_05.e05_n01_maya_memory.event1.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "He was the worst liar of all of us.",
          "textKey": "episode_05.e05_n01_maya_memory.event2.text"
        }
      ],
      "nextNodeId": "e05_n02"
    },
