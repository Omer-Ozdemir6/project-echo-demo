{
  "id": "episode_05",
  "title": "THE SIX",
  "startNodeId": "e05_n01",
  "nodes": {
    "e05_n01": {
      "id": "e05_n01",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2000
        },
        {
          "type": "message",
          "text": "If we're going to survive, you need to know who we were.",
          "textKey": "episode_05.e05_n01.event1.text"
        },
        {
          "type": "message",
          "text": "ECHO wasn't run by one person, no matter how much Hale liked that idea.",
          "textKey": "episode_05.e05_n01.event2.text"
        },
        {
          "type": "message",
          "text": "There were six of us.",
          "textKey": "episode_05.e05_n01.event3.text"
        }
      ],
      "nextNodeId": "e05_n02"
    },
    "e05_n02": {
      "id": "e05_n02",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "crew",
          "id": "crew_manifest_01",
          "title": "CREW MANIFEST",
          "content": "01 Ethan Hale\n02 Maya Chen\n03 Grant Walker\n04 Rivera Torres\n05 Owen Park\n06 Sarah Owens",
          "titleKey": "episode_05.e05_n02.event0.title",
          "contentKey": "episode_05.e05_n02.event0.content"
        }
      ],
      "nextNodeId": "e05_n03"
    },
    "e05_n03": {
      "id": "e05_n03",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2000
        },
        {
          "type": "message",
          "text": "Grant handled security. Head of Not Dying, he called himself.",
          "textKey": "episode_05.e05_n03.event1.text"
        },
        {
          "type": "message",
          "text": "Rivera managed logistics. Park and Owens were stuck in the lower sectors. Nobody liked the lower sectors.",
          "textKey": "episode_05.e05_n03.event2.text"
        },
        {
          "type": "message",
          "text": "Park pretended he did. Owens called him a liar every morning.",
          "textKey": "episode_05.e05_n03.event3.text"
        }
      ],
      "nextNodeId": "e05_n04"
    },
    "e05_n04": {
      "id": "e05_n04",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "image",
          "src": "/images/crew_photo_01.jpg"
        }
      ],
      "nextNodeId": "e05_n05"
    },
    "e05_n05": {
      "id": "e05_n05",
      "speaker": "MAYA",
      "events": [
        {
          "type": "message",
          "text": "I used to hate this photo. Grant blinked, Rivera refused to smile, and Hale looked ready to kill the photographer.",
          "textKey": "episode_05.e05_n05.event0.text"
        },
        {
          "type": "message",
          "text": "Count them. Look closely.",
          "textKey": "episode_05.e05_n05.event1.text"
        }
      ],
      "nextNodeId": "e05_n06"
    },
    "e05_n06": {
      "id": "e05_n06",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "systemAlert",
          "text": "[IMAGE ANALYSIS: DETECTED PERSONNEL: 7]",
          "textKey": "episode_05.e05_n06.event0.text"
        },
        {
          "type": "message",
          "speaker": "MAYA",
          "text": "Exactly. That's impossible. Six bunks. Six suits. We don't bring extras.",
          "textKey": "episode_05.e05_n06.event1.text"
        }
      ],
      "nextNodeId": "e05_n08"
    },
    "e05_n08": {
      "id": "e05_n08",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "systemAlert",
          "text": "[CORRUPTED ARCHIVE LAYER DETECTED]",
          "textKey": "episode_05.e05_n08.event0.text"
        },
        {
          "type": "file",
          "id": "manifest_v2",
          "title": "MANIFEST_V2",
          "content": "07 █████████",
          "titleKey": "episode_05.e05_n08.event1.title",
          "contentKey": "episode_05.e05_n08.event1.content"
        }
      ],
      "nextNodeId": "e05_n09"
    },
    "e05_n09": {
      "id": "e05_n09",
      "speaker": "MAYA",
      "events": [
        {
          "type": "message",
          "text": "I don't know who Number 7 is. That name shouldn't exist.",
          "textKey": "episode_05.e05_n09.event0.text"
        },
        {
          "type": "glitch",
          "duration": 1000
        },
        {
          "type": "corruptMessage",
          "speaker": "UNKNOWN",
          "text": "YOU ALREADY SAW MY NAME.",
