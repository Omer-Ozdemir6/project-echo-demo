          "nextNodeId": "e05_n03",
          "textKey": "episode_05.e05_n02.choice0.text"
        }
      ]
    },
    "e05_n03": {
      "id": "e05_n03",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Grant handled security.",
          "textKey": "episode_05.e05_n03.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "He called himself Head of Not Dying.",
          "textKey": "episode_05.e05_n03.event3.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Rivera managed logistics. If something moved on this station, Rivera knew where it came from, where it was going, and who was about to complain about it.",
          "textKey": "episode_05.e05_n03.event5.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Park and Owens maintained the lower sectors.",
          "textKey": "episode_05.e05_n03.event7.text"
        },
        {
          "type": "pause",
          "duration": 1000
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "Nobody liked the lower sectors.",
          "textKey": "episode_05.e05_n03.event10.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Park pretended he did. Owens called him a liar every morning.",
          "textKey": "episode_05.e05_n03.event12.text"
        }
      ],
      "choices": [
        {
          "id": "continue_team",
          "text": "CONTINUE.",
          "nextNodeId": "e05_n04",
          "textKey": "episode_05.e05_n03.choice0.text"
        }
      ]
    },
    "e05_n04": {
      "id": "e05_n04",
      "speaker": "SYSTEM",
      "events": [
