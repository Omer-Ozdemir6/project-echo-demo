          "type": "typing",
          "duration": 4600
        },
        {
          "type": "message",
          "text": "I don't know."
        },
        {
          "type": "pause",
          "duration": 1200
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "And that's the part that scares me."
        },
        {
          "type": "typing",
          "duration": 4800
        },
        {
          "type": "message",
          "text": "I remember every person on this station."
        },
        {
          "type": "typing",
          "duration": 4400
        },
        {
          "type": "message",
          "text": "Even the ones I wish I could forget."
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That name shouldn't exist."
