    "e05_n03_hale_role": {
      "id": "e05_n03_hale_role",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Hale kept the station breathing.",
          "textKey": "episode_05.e05_n03_hale_role.event1.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Power, relay routing, pressure control, emergency doors. If something opened or closed, Hale had a way into it.",
          "textKey": "episode_05.e05_n03_hale_role.event3.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "He corrected reports in red. Digital reports. Red comments. In space.",
          "textKey": "episode_05.e05_n03_hale_role.event5.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "I told him that was hostile. He said accuracy wasn't a friendship contest.",
          "textKey": "episode_05.e05_n03_hale_role.event7.text"
        },
        {
          "type": "pause",
          "duration": 800
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "The real Hale was hard to like sometimes.",
          "textKey": "episode_05.e05_n03_hale_role.event10.text"
        },
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "But he was ours.",
          "textKey": "episode_05.e05_n03_hale_role.event12.text"
        }
      ],
      "nextNodeId": "e05_n03_move_life_support"
    },
    "e05_n03_move_life_support": {
      "id": "e05_n03_move_life_support",
      "speaker": "MAYA",
      "events": [
