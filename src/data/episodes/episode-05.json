  "nodes": {
    "e05_n01": {
      "id": "e05_n01",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "If we're going to survive, you need to know who we were.",
          "textKey": "episode_05.e05_n01.event0.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Not just names on a manifest.",
          "textKey": "episode_05.e05_n01.event3.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Names are what the station keeps after it has already failed the people attached to them.",
          "textKey": "episode_05.e05_n01.event5.text"
        },
        {
          "type": "pause",
          "duration": 800
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "ECHO wasn't run by one person, no matter how much Hale liked that idea.",
          "textKey": "episode_05.e05_n01.event1.text"
        },
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "He would deny that, by the way.",
          "textKey": "episode_05.e05_n01.event10.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Then he would explain exactly why everyone else was technically wrong.",
          "textKey": "episode_05.e05_n01.event12.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "There were six of us.",
          "textKey": "episode_05.e05_n01.event2.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "At least, that's what the official manifest says.",
          "textKey": "episode_05.e05_n01.event3.text"
        },
        {
          "type": "pause",
          "duration": 900
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "I used to trust official things.",
          "textKey": "episode_05.e05_n01.event19.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Bad habit.",
          "textKey": "episode_05.e05_n01.event21.text"
        }
      ],
      "choices": [
        {
          "id": "pull_manifest",
          "text": "PULL THE OFFICIAL MANIFEST.",
          "effects": {
            "mayaTrust": 2,
            "signalStrength": 1
          },
          "nextNodeId": "e05_n02",
          "textKey": "episode_05.e05_n01.choice0.text"
        },
        {
          "id": "ask_maya_first",
          "text": "TELL ME WHO THEY WERE.",
          "effects": {
            "mayaTrust": 3,
            "morale": -1
          },
          "nextNodeId": "e05_n01_maya_memory",
          "textKey": "episode_05.e05_n01.choice1.text"
        }
      ]
    },
    "e05_n01_maya_memory": {
      "id": "e05_n01_maya_memory",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "Grant acted like everything was a security drill. He called himself Head of Not Dying.",
          "textKey": "episode_05.e05_n01_maya_memory.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Rivera solved problems before anyone finished explaining them.",
          "textKey": "episode_05.e05_n01_maya_memory.event3.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "That sounds useful until you're halfway through a sentence and she has already fixed your mistake and judged your childhood.",
          "textKey": "episode_05.e05_n01_maya_memory.event5.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Park made jokes when he was scared. Owens pretended not to laugh.",
          "textKey": "episode_05.e05_n01_maya_memory.event7.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Nobody believed her. Especially Park.",
          "textKey": "episode_05.e05_n01_maya_memory.event9.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Hale pretended he didn't need anyone.",
          "textKey": "episode_05.e05_n01_maya_memory.event1.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "He was the worst liar of all of us.",
          "textKey": "episode_05.e05_n01_maya_memory.event2.text"
        },
        {
          "type": "pause",
          "duration": 800
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Grant treated every maintenance request like a security threat.",
          "textKey": "episode_05.e05_n01_maya_memory.event16.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "Owens called him paranoid. Grant called that 'evidence of poor threat assessment.'",
          "textKey": "episode_05.e05_n01_maya_memory.event18.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "We laughed at him. Mostly because he was usually right.",
          "textKey": "episode_05.e05_n01_maya_memory.event20.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That's what hurts, I think.",
          "textKey": "episode_05.e05_n01_maya_memory.event22.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "The station didn't erase strangers.",
          "textKey": "episode_05.e05_n01_maya_memory.event24.text"
        },
        {
          "type": "typing",
          "duration": 4000
        },
        {
          "type": "message",
          "text": "It erased people who had annoying habits. Bad jokes. Favorite mugs. Arguments that never got finished.",
          "textKey": "episode_05.e05_n01_maya_memory.event26.text"
        }
      ],
      "nextNodeId": "e05_n02"
    },
    "e05_n02": {
      "id": "e05_n02",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "crew",
          "id": "crew_manifest_01",
          "fileId": "crew_manifest_01",
          "fileType": "crew",
          "title": "CREW MANIFEST",
          "content": "01 Ethan Hale\n02 Maya Chen\n03 Grant Walker\n04 Rivera Torres\n05 Owen Park\n06 Sarah Owens",
          "caption": "Recovered official ECHO crew manifest.",
          "source": "PERSONNEL_ARCHIVE",
          "tags": [
