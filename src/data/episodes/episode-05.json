{
  "id": "episode_05",
  "title": "THE SIX",
  "startNodeId": "e05_n01",
  "nodes": {
    "e05_n01": {
      "id": "e05_n01",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "If we're going to survive, you need to know who we were.",
          "textKey": "episode_05.e05_n01.event1.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "ECHO wasn't run by one person, no matter how much Hale liked that idea.",
          "textKey": "episode_05.e05_n01.event2.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "There were six of us.",
          "textKey": "episode_05.e05_n01.event3.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "At least, that's what the official manifest says.",
          "textKey": "episode_05.e05_n01.event4.text"
        }
      ],
      "nextNodeId": "e05_n02"
    },
    "e05_n02": {
      "id": "e05_n02",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "crew",
          "id": "crew_manifest_01",
          "fileId": "crew_manifest_01",
          "fileType": "crew",
          "title": "CREW MANIFEST",
          "content": "01 Ethan Hale\n02 Maya Chen\n03 Grant Walker\n04 Rivera Torres\n05 Owen Park\n06 Sarah Owens",
          "caption": "Recovered official ECHO crew manifest.",
          "message": "[CREW MANIFEST ARCHIVED TO DATA BANK]",
          "titleKey": "episode_05.e05_n02.event0.title",
          "contentKey": "episode_05.e05_n02.event0.content",
          "captionKey": "episode_05.e05_n02.event0.caption",
          "messageKey": "episode_05.e05_n02.event0.message"
        }
      ],
      "nextNodeId": "e05_n03"
    },
    "e05_n03": {
      "id": "e05_n03",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "Grant handled security. Head of Not Dying, he called himself.",
          "textKey": "episode_05.e05_n03.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "Rivera managed logistics. Park and Owens were stuck in the lower sectors.",
          "textKey": "episode_05.e05_n03.event2.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Nobody liked the lower sectors. Park pretended he did. Owens called him a liar every morning.",
          "textKey": "episode_05.e05_n03.event3.text"
        }
      ],
      "choices": [
        {
          "id": "ask_about_hale_role",
          "text": "WHAT WAS HALE'S ROLE?",
          "effects": {
            "mayaTrust": 3,
            "danger": 1
          },
          "nextNodeId": "e05_n03_hale",
          "textKey": "episode_05.e05_n03.choice0.text"
        },
        {
          "id": "ask_about_photo",
          "text": "SHOW ME THE PHOTO.",
          "effects": {
            "mayaTrust": 1
          },
          "nextNodeId": "e05_n04",
          "textKey": "episode_05.e05_n03.choice1.text"
        }
      ]
    },
    "e05_n03_hale": {
      "id": "e05_n03_hale",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "Hale kept the station breathing.",
          "textKey": "episode_05.e05_n03_hale.event0.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Power, relay routing, pressure control, emergency doors. If something opened or closed, Hale probably had a way into it.",
          "textKey": "episode_05.e05_n03_hale.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "That's why I don't like hearing his voice in places it shouldn't be.",
          "textKey": "episode_05.e05_n03_hale.event2.text"
        }
      ],
      "nextNodeId": "e05_n04"
    },
    "e05_n04": {
      "id": "e05_n04",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "image",
          "id": "crew_photo_01",
          "fileId": "crew_photo_01",
          "fileType": "image",
          "title": "CREW PHOTO",
          "caption": "Recovered ECHO crew photograph. Image analysis pending.",
          "src": "/images/crew_photo_01.jpg",
          "source": "PERSONNEL_ARCHIVE",
          "tags": [
            "crew",
            "photo",
            "manifest"
          ],
          "message": "[CREW PHOTO ARCHIVED TO DATA BANK]",
          "titleKey": "episode_05.e05_n04.event0.title",
          "captionKey": "episode_05.e05_n04.event0.caption",
          "messageKey": "episode_05.e05_n04.event0.message"
        }
      ],
      "nextNodeId": "e05_n05"
    },
    "e05_n05": {
      "id": "e05_n05",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "I used to hate this photo.",
          "textKey": "episode_05.e05_n05.event0.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Grant blinked, Rivera refused to smile, and Hale looked ready to kill the photographer.",
          "textKey": "episode_05.e05_n05.event1.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Count them. Look closely.",
          "textKey": "episode_05.e05_n05.event2.text"
        }
      ],
      "choices": [
        {
          "id": "run_image_analysis",
          "text": "RUN IMAGE ANALYSIS.",
          "effects": {
            "mayaTrust": 2,
            "signalStrength": -2
          },
          "nextNodeId": "e05_n06",
          "textKey": "episode_05.e05_n05.choice0.text"
        },
        {
          "id": "ask_maya_first",
          "text": "WHAT AM I LOOKING FOR?",
          "effects": {
            "mayaTrust": -2,
            "danger": 2
          },
          "nextNodeId": "e05_n05_ask",
          "textKey": "episode_05.e05_n05.choice1.text"
        }
      ]
    },
    "e05_n05_ask": {
      "id": "e05_n05_ask",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Don't make me say it first.",
          "textKey": "episode_05.e05_n05_ask.event0.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "If I tell you what to see, you'll wonder if I planted the idea.",
          "textKey": "episode_05.e05_n05_ask.event1.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "Run the analysis.",
          "textKey": "episode_05.e05_n05_ask.event2.text"
        }
      ],
      "nextNodeId": "e05_n06"
    },
    "e05_n06": {
      "id": "e05_n06",
      "speaker": "SYSTEM",
      "events": [
        {
          "type": "systemAlert",
          "text": "[IMAGE ANALYSIS STARTED]",
          "pauseAfterMs": 900,
          "textKey": "episode_05.e05_n06.event0.text"
        },
        {
          "type": "progressTask",
          "id": "crew_photo_analysis",
          "title": "ANALYZING PERSONNEL IMAGE",
          "subtitle": "Detecting visible biometric signatures",
          "duration": 5000,
          "completeText": "[IMAGE ANALYSIS COMPLETE]",
          "titleKey": "episode_05.e05_n06.event1.title",
          "subtitleKey": "episode_05.e05_n06.event1.subtitle",
          "completeTextKey": "episode_05.e05_n06.event1.completeText"
