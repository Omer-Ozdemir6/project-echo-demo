        {
          "type": "message",
          "text": "Six names.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n02_manifest.event2.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "That's the official story.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n02_manifest.event4.text"
        },
        {
          "type": "typing",
          "duration": 2800
        },
        {
          "type": "message",
          "text": "Official stories are very confident right up until they start bleeding.",
          "speaker": "MAYA",
          "textKey": "episode_05.e05_n02_manifest.event6.text"
        }
      ],
      "choices": [
        {
          "id": "ask_hale_role",
          "text": "ASK WHAT HALE CONTROLLED.",
          "effects": {},
          "nextNodeId": "e05_n03_hale_role",
          "nextEpisodeId": {
            "mayaTrust": 2,
            "haleTrust": -1
          },
          "textKey": "episode_05.e05_n02_manifest.choice0.text"
        },
        {
          "id": "send_to_life_support",
          "text": "SEND MAYA TO LIFE SUPPORT INDEX.",
          "effects": {},
          "nextNodeId": "e05_n03_move_life_support",
