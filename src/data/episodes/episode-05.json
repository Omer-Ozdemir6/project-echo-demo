    "e05_n09": {
      "id": "e05_n09",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 4600
        },
        {
          "type": "message",
          "text": "I don't know.",
          "textKey": "episode_05.e05_n09.event1.text"
        },
        {
          "type": "pause",
          "duration": 1200
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "And that's the part that scares me.",
          "textKey": "episode_05.e05_n09.event4.text"
        },
        {
          "type": "typing",
          "duration": 4800
        },
        {
          "type": "message",
          "text": "I remember every person on this station.",
          "textKey": "episode_05.e05_n09.event6.text"
        },
        {
          "type": "typing",
          "duration": 4400
        },
        {
          "type": "message",
          "text": "Even the ones I wish I could forget.",
          "textKey": "episode_05.e05_n09.event8.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That name shouldn't exist.",
          "textKey": "episode_05.e05_n09.event10.text"
        }
      ],
      "choices": [
        {
          "id": "continue_corruption",
          "text": "CONTINUE.",
          "nextNodeId": "e05_n10",
          "textKey": "episode_05.e05_n09.choice0.text"
        }
      ]
