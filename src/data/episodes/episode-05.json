{
  "id": "episode_05",
  "title": "THE SIX",
  "startNodeId": "e05_n01",
  "puzzles": {},
  "nodes": {
    "e05_n01": {
      "id": "e05_n01",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "If we're going to survive this, you need to know who we were.",
          "textKey": "episode_05.e05_n01.event1.text"
        },
        {
          "type": "pause",
          "duration": 1000
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "ECHO wasn't run by one person.",
          "textKey": "episode_05.e05_n01.event4.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "No matter how much Hale enjoyed sounding like he owned the place.",
          "textKey": "episode_05.e05_n01.event6.text"
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "There were six of us.",
          "textKey": "episode_05.e05_n01.event8.text"
        }
      ],
      "choices": [
        {
          "id": "show_crew",
          "text": "SHOW ME.",
          "nextNodeId": "e05_n02",
          "textKey": "episode_05.e05_n01.choice0.text"
        }
      ]
    },
    "e05_n02": {
      "id": "e05_n02",
