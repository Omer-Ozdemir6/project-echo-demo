          "type": "typing",
          "duration": 3400
        },
        {
          "type": "message",
          "text": "Hale kept the station breathing.",
          "textKey": "episode_05.e05_n03_hale.event0.text"
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "Power, relay routing, pressure control, emergency doors. If something opened or closed, Hale probably had a way into it.",
          "textKey": "episode_05.e05_n03_hale.event1.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "That's why I don't like hearing his voice in places it shouldn't be.",
          "textKey": "episode_05.e05_n03_hale.event2.text"
        }
      ],
      "nextNodeId": "e05_n04"
