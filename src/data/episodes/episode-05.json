      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "If we're going to survive this, you need to know who we were."
        },
        {
          "type": "pause",
          "duration": 1000
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "ECHO wasn't run by one person."
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "No matter how much Hale enjoyed sounding like he owned the place."
        },
        {
          "type": "typing",
          "duration": 3200
        },
        {
          "type": "message",
          "text": "There were six of us."
        }
      ],
      "choices": [
        {
          "id": "show_crew",
          "text": "SHOW ME.",
          "nextNodeId": "e05_n02"
        }
      ]
    },
