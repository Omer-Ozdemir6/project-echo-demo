    "e05_n09": {
      "id": "e05_n09",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "I don't know who Number 7 is.",
          "textKey": "episode_05.e05_n09.event0.text"
        },
        {
          "type": "typing",
          "duration": 4000
        },
        {
          "type": "message",
