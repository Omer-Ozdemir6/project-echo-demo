        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "There are two ways to life support from here.",
          "textKey": "episode_05.e05_n03_move_life_support.event5.text"
        },
        {
          "type": "typing",
          "duration": 2800
        },
        {
          "type": "message",
          "text": "Main corridor is faster. Maintenance crawl is quieter.",
          "textKey": "episode_05.e05_n03_move_life_support.event7.text"
        }
