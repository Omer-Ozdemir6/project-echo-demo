    "e05_n05": {
      "id": "e05_n05",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "I used to hate that photo.",
          "textKey": "episode_05.e05_n05.event1.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Grant blinked. Rivera refused to smile. Hale looked like he was about to fire the camera.",
          "textKey": "episode_05.e05_n05.event3.text"
        },
        {
          "type": "pause",
          "duration": 1200
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "But something about it always bothered me.",
          "textKey": "episode_05.e05_n05.event6.text"
        },
        {
          "type": "typing",
          "duration": 2400
        },
        {
          "type": "message",
          "text": "Count them.",
          "textKey": "episode_05.e05_n05.event8.text"
        }
      ],
      "choices": [
        {
          "id": "count_people",
          "text": "COUNT CREW MEMBERS.",
          "nextNodeId": "e05_n06",
          "textKey": "episode_05.e05_n05.choice0.text"
        }
      ]
    },
