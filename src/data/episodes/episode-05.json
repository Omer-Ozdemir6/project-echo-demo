        }
      ],
      "choices": [
        {
          "id": "seven_people",
          "text": "THERE ARE SEVEN PEOPLE.",
          "nextNodeId": "e05_n07",
          "textKey": "episode_05.e05_n06.choice0.text"
        }
      ]
    },
    "e05_n07": {
      "id": "e05_n07",
      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Exactly.",
          "textKey": "episode_05.e05_n07.event1.text"
        },
        {
          "type": "pause",
          "duration": 1300
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That's impossible.",
          "textKey": "episode_05.e05_n07.event4.text"
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "There were six bunks. Six suits. Six oxygen licenses.",
          "textKey": "episode_05.e05_n07.event6.text"
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "On a station like ECHO, you don't accidentally bring an extra person.",
          "textKey": "episode_05.e05_n07.event8.text"
        }
      ],
      "choices": [
        {
          "id": "continue_seven",
          "text": "CONTINUE.",
          "nextNodeId": "e05_n08",
          "textKey": "episode_05.e05_n07.choice0.text"
        }
      ]
    },
