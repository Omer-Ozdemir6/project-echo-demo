        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Exactly."
        },
        {
          "type": "pause",
          "duration": 1300
        },
        {
          "type": "typing",
          "duration": 4200
        },
        {
          "type": "message",
          "text": "That's impossible."
        },
        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "There were six bunks. Six suits. Six oxygen licenses."
        },
        {
          "type": "typing",
          "duration": 3800
        },
        {
          "type": "message",
          "text": "On a station like ECHO, you don't accidentally bring an extra person."
        }
      ],
