        {
          "id": "leave_pod",
          "text": "LEAVE THE POD.",
          "effects": {
            "danger": -10,
            "morale": -15,
            "trust": 5
          },
          "nextNodeId": "e08_n06b",
          "textKey": "episode_08.e08_n05.choice1.text"
