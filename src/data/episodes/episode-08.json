      "speaker": "MAYA",
      "events": [
        {
          "type": "typing",
          "duration": 1800
        },
        {
          "type": "message",
          "text": "We can still reach it. Not easily. Not safely. Honestly, not in any way that makes my survival instincts happy. But there is someone inside.",
          "textKey": "episode_08.e08_n04.event1.text"
        }
      ],
      "nextNodeId": "e08_n05"
    },
    "e08_n05": {
      "id": "e08_n05",
      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 1600
        },
        {
          "type": "message",
          "text": "No. Leave it.",
          "textKey": "episode_08.e08_n05.event1.text"
        },
        {
          "type": "typing",
          "duration": 2200
        },
        {
          "type": "message",
          "text": "Whatever is inside that pod is not worth the risk. And before Maya says I sound heartless, I know exactly how I sound. That is why you should listen.",
          "textKey": "episode_08.e08_n05.event3.text"
        }
      ],
      "choices": [
        {
          "id": "save_occupant",
          "text": "SAVE THE OCCUPANT.",
