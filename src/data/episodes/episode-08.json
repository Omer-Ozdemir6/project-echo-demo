      "speaker": "HALE",
      "events": [
        {
          "type": "typing",
          "duration": 2300
        },
        {
          "type": "message",
          "text": "No. Voss is dead.",
          "textKey": "episode_08.e08_n10.event1.text"
        },
        {
          "type": "typing",
          "duration": 2600
        },
        {
          "type": "message",
          "text": "I saw the body myself. And if that thing is using his suit ID, then it is not asking for help. It is baiting us.",
