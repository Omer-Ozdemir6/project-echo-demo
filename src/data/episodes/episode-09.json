        {
          "type": "typing",
          "duration": 3600
        },
        {
          "type": "message",
          "text": "The pod beacon is ahead of me, but it keeps sliding in and out of the relay map like it doesn't want to be found.",
          "textKey": "episode_09.e09_n01.event3.text"
        },
        {
          "type": "typing",
          "duration": 3000
        },
        {
          "type": "message",
          "text": "Life support is dropping. I can see the pulse in the telemetry.",
