        "title": "THE OBSERVER"
      }
    },
    "observer_fragment_chain": {
      "puzzle0": {
        "title": "OBSERVER SIGNAL",
        "description": "A repeating numerical pattern hidden in Observer transmissions."
      }
    },
    "e37_n01": {
      "event0": {
        "text": "[OBSERVER SIGNAL ACTIVE]"
      },
      "event1": {
        "text": "I don't like that name."
      },
      "event2": {
        "text": "Observer?"
      },
      "event3": {
        "text": "No."
      },
      "event4": {
        "text": "The fact that it's active."
      },
      "event5": {
        "text": "Agreed."
      }
    },
    "e37_talk": {
      "event0": {
        "text": "Daniel followed me."
      },
      "event1": {
        "text": "You let him see you?"
      },
      "event2": {
        "text": "I didn't think—"
      },
      "event3": {
        "text": "No."
      },
      "event4": {
        "text": "You didn't."
      }
    },
    "e37_hide": {
      "event0": {
        "text": "You should've spoken to him."
      },
      "event1": {
        "text": "And you would've yelled at me if I did."
      },
      "event2": {
        "text": "Probably."
      },
      "event3": {
        "text": "But at least then we'd know what he wanted."
      }
    },
    "e37_common_01": {
      "event0": {
        "title": "OBSERVER FRAGMENT 01",
        "content": "0 2 7\n\n7 2 0\n\n2 0 7"
      },
      "event1": {
        "text": "[OBSERVER PATTERN FRAGMENT RECOVERED: 1/3]"
      },
      "event2": {
        "text": "Great."
      },
      "event3": {
        "text": "Numbers."
      },
      "event4": {
        "text": "My favorite."
      },
      "event5": {
        "text": "Your favorite is complaining."
      },
      "event6": {
        "text": "Numbers are second."
      }
    },
    "e37_common_02": {
      "event1": {
        "text": "Can I ask something?"
      },
      "event2": {
        "text": "Sure."
      },
      "event3": {
        "text": "Evelyn."
      },
      "event5": {
        "text": "Do you still love her?"
      },
      "event7": {
        "text": "That's the problem."
      },
      "event8": {
        "text": "I don't remember enough of her to know."
      },
      "event9": {
        "text": "Sometimes I remember her laugh."
      },
      "event10": {
        "text": "Then I forget it again."
      },
      "event11": {
        "text": "That scares me more than AEON."
      },
      "event12": {
        "text": "And I hate that."
      }
    },
    "e37_trace": {
      "event0": {
        "text": "[OBSERVER TRACE STARTED]"
      }
    },
    "e37_waiting": {
      "event0": {
        "text": "Tracing Observer signal..."
      },
      "event1": {
        "text": "Pattern lock unstable."
      }
    },
    "e37_final": {
      "event0": {
        "text": "SOURCE LOCATION FOUND"
      },
      "event1": {
        "title": "OBSERVER ORIGIN",
        "content": "ORIGIN\n\nNODE 00"
      },
      "event3": {
        "text": "No."
      },
      "event4": {
        "text": "That's impossible."
      },
      "event5": {
        "text": "Node 00 was erased."
      },
      "event6": {
        "text": "Erased by who?"
      },
      "event7": {
        "text": "What's Node 00?"
      },
      "event9": {
        "text": "Nobody was supposed to know about Node 00."
      },
      "event10": {
        "text": "I never left."
      }
    }
  }
