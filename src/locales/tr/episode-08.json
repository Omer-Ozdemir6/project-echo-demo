{
  "episode_08": {
    "meta": {
      "title": "THE EIGHTH PASSENGER — ECHO DIRECTOR'S CUT V7"
    },
    "e08_n01": {
      "event1": {
        "text": "I found it."
      },
      "event4": {
        "text": "The one the archive said would remember."
      },
      "event8": {
        "text": "Not dying."
      },
      "event10": {
        "text": "Caught in the antenna frame."
      },
      "event13": {
        "text": "Like it tried to leave."
      },
      "event6": {
        "text": "Like something grabbed it halfway out."
      },
      "event17": {
        "text": "Beacon is blinking."
      },
      "event19": {
        "text": "Not random."
      },
      "backgroundEvent12": {
        "text": "...help..."
      },
      "event24": {
        "text": "There."
      },
      "event14": {
        "text": "Tell me you heard that too."
      },
      "choice0": {
        "text": "RUN A REMOTE SCAN FIRST."
      },
      "choice1": {
        "text": "GUIDE MAYA CLOSER TO THE POD."
      }
    },
    "e08_n02_scan": {
      "event1": {
        "text": "Good."
      },
      "event3": {
        "text": "Scan first."
      },
      "event5": {
        "text": "Relay against the support strut."
      },
      "event8": {
        "text": "I do.",
        "message": "[MAYA IS CHECKING THE POD]"
      },
      "event10": {
        "text": "That's the problem."
      },
      "event14": {
        "text": "Beacon line is thin."
      },
      "event16": {
        "text": "If I breathe wrong, we lose it."
      },
      "event18": {
        "text": "Going quiet."
      }
    },
    "e08_r02_scan_return": {
      "event1": {
        "text": "Got it."
      },
      "event6": {
        "text": "Someone's in there."
      },
      "event8": {
        "text": "And calling it a tool."
      },
      "event10": {
        "text": "You made the right call."
      },
      "event12": {
        "text": "Don't get smug."
      },
      "event4": {
        "title": "POD MANIFEST",
        "content": "Occupant: UNKNOWN\nLife Support: 23%\nPressure: unstable but contained\nBeacon Origin: external emergency pod\nVisual Feed: unavailable\nManual Access: possible\nWarning: identity not confirmed\nCarrier Residue: 7.14 MHz harmonic",
        "caption": "Remote scan confirms an active life-support pod with an unknown occupant.",
        "message": "[POD MANIFEST ARCHIVED TO DATA BANK]"
      },
      "event17": {
        "text": "Whoever it is doesn't have time."
      },
      "event19": {
        "text": "I can open it. That's the part I hate."
      },
      "event22": {
        "text": "That feels like the station handing me a knife."
      }
    },
    "e08_n02_approach": {
      "event1": {
        "text": "Okay. Closer."
      },
      "event3": {
        "text": "Say it looked heroic."
      },
      "event5": {
        "text": "Right side is just dark."
      },
      "event7": {
        "text": "Why not."
      },
      "event10": {
        "text": "Clip's fighting me. Give me a second."
      },
      "event12": {
        "text": "If I drift away, lie."
      },
      "event16": {
        "text": "Nothing under my boots except bad decisions."
      },
      "event18": {
        "text": "Broken antenna ribs left."
      },
      "backgroundEvent21": {
        "text": "Something tapped the pod again."
      },
      "backgroundEvent22": {
        "text": "No. Not looking while crossing."
      },
      "event24": {
        "text": "Both hands."
      },
      "event8": {
        "message": "[MAYA IS CROSSING GANTRY]"
      }
    },
    "e08_r02_approach_return": {
      "event2": {
        "text": "Close enough to see frost on the hatch."
      },
      "event7": {
        "text": "No visual through the port."
      },
      "event9": {
        "text": "Just me."
      },
      "event11": {
        "text": "My reflection looks furious."
      },
      "event4": {
        "text": "Probably fair."
      },
      "event6": {
        "text": "The pod corrected its drift while I crossed."
      },
      "event17": {
        "text": "Just a little."
      },
      "event8": {
        "text": "Enough to prove it isn't wreckage."
      },
      "backgroundEvent9": {
        "text": "cold"
      },
      "event22": {
        "text": "You sent me in close before we knew that."
      },
      "event24": {
        "text": "Remember that."
      }
    },
    "e08_n03_route": {
      "event1": {
        "text": "Two ways to the hatch."
      },
      "event3": {
        "text": "Physics waiting to make a point."
      },
      "event5": {
        "text": "Damaged housing."
      },
      "event7": {
        "text": "Third option is waking up somewhere safe."
      },
      "event9": {
        "text": "Ugly."
      },
      "event14": {
        "text": "Long path."
      },
      "event16": {
        "text": "Maintenance tether."
      },
      "event18": {
        "text": "Less exposed."
      },
      "event24": {
        "text": "Apparently unavailable."
      },
      "choice0": {
        "text": "TAKE THE EXPOSED ANTENNA RIB."
      },
      "choice1": {
        "text": "TAKE THE MAINTENANCE TETHER."
      }
    },
    "e08_n04_rib": {
      "event1": {
        "text": "Fast route. Of course we picked the sharp one."
      },
      "event3": {
        "text": "I'm stepping onto the rib. It is narrower than it looked from back there."
      },
      "event5": {
        "text": "No talking while I cross. If I hear myself panic, I may start agreeing with it."
      },
      "event6": {
        "message": "[MAYA IS CROSSING RIB]"
      }
    },
    "e08_r04_rib_return": {
      "event2": {
        "text": "At the hatch frame."
      },
      "event5": {
        "text": "I thought I was gone."
      },
      "event7": {
        "text": "Rib flexed."
      },
      "event9": {
        "text": "Tether snapped tight."
      },
      "event11": {
        "text": "My whole suit rang."
      },
      "event13": {
        "text": "I said several words."
      },
      "event4": {
        "text": "Vacuum can keep them."
      },
      "event17": {
        "text": "I'm here."
      },
      "event19": {
        "text": "Fast."
      },
      "event21": {
        "text": "Not free."
      },
      "event24": {
        "text": "There's a white scrape across my suit now."
      },
      "event26": {
        "text": "Fast route signed its name."
      }
    },
    "e08_n04_tether": {
      "event1": {
        "text": "Tether path. Slow and less stupid."
      },
      "event3": {
        "text": "Sensible. I hate how much I appreciate sensible right now."
      },
      "event5": {
        "text": "Handhold first. Then suit line. Then the next breath."
      },
      "event7": {
        "text": "This will take longer. Don't make a speech while I'm gone. I won't hear it."
      },
      "event8": {
        "message": "[MAYA IS MOVING THROUGH TETHER]"
      }
    },
    "e08_r04_tether_return": {
      "event1": {
        "text": "At the hatch frame."
      },
      "event3": {
        "text": "Scratches inside the tether housing."
      },
      "event5": {
        "text": "Or someone dragged something through it."
      },
      "event10": {
        "text": "Fresh."
      },
      "event12": {
        "text": "Dust hasn't settled."
      },
      "event14": {
        "text": "Something used this route."
      },
      "event19": {
        "text": "Good news."
      },
      "event21": {
        "text": "My line is fine."
      },
      "event23": {
        "text": "Bad news."
      },
      "event7": {
        "text": "My imagination isn't."
      },
      "event28": {
        "text": "We bought safety with minutes."
      },
      "event30": {
        "text": "I hope Noah had minutes to spare."
      }
    },
    "e08_n05_hatch": {
      "event1": {
        "text": "I'm at the hatch."
      },
      "event3": {
        "text": "Tiny pulses through the frame."
      },
      "event8": {
        "text": "Hale went quiet."
      },
      "event10": {
        "text": "Hale?"
      },
      "event12": {
        "text": "Step back from it."
      },
      "event14": {
        "text": "The calm voice."
      },
      "event5": {
        "text": "Heartbeat, maybe."
      },
      "event20": {
        "text": "That's never good."
      },
      "event26": {
        "text": "There it is."
      },
      "event30": {
        "text": "Maya, please."
      },
      "event16": {
        "text": "That pod should not be here."
      },
      "choice0": {
        "text": "VERIFY BEFORE TOUCHING THE HATCH."
      },
      "choice1": {
        "text": "LET MAYA START MANUAL CONTACT."
      }
    },
    "e08_n06_verify": {
      "event1": {
        "text": "Thank you."
      },
      "event3": {
        "text": "Like fear in a lab coat."
      },
      "event7": {
        "text": "Maya, give me thirty seconds."
      },
      "event9": {
        "text": "You get twenty."
      },
      "event5": {
        "text": "it isn't passive wreckage."
      },
      "event17": {
        "text": "And Operator?"
      },
      "event19": {
        "text": "I'm noticing you picked his fear over mine."
      },
      "event21": {
        "text": "Running it. And trying not to hear her breathing at the hatch."
      },
      "event12": {
        "message": "[HALE IS CHECKING THE HATCH]"
      }
    },
    "e08_r06_verify_return": {
      "event1": {
        "text": "I have it."
      },
      "event2": {
        "title": "POD HATCH INTEGRITY",
        "content": "Seal: intact\nExternal frost: fresh\nManual lever: responsive\nMotion correction: active\nCarrier residue: 7.14 MHz harmonic\nRisk: opening may trigger automatic occupant revival sequence",
        "caption": "Hatch check shows active 7.14 residue and a possible automatic revival sequence.",
        "message": "[POD HATCH INTEGRITY ARCHIVED TO DATA BANK]"
      },
      "event4": {
        "text": "Automatic revival sequence."
      },
      "event6": {
        "text": "That phrase should require a permit."
      },
      "event9": {
        "text": "You were right to verify."
      },
      "event11": {
        "text": "Do not sound pleased."
      },
      "event14": {
        "text": "Maya hasn't forgiven the pause."
      },
      "event16": {
        "text": "I can hear it in how quiet she got."
      }
    },
    "e08_n06_contact": {
      "event1": {
        "text": "Hand on the hatch."
      },
      "event3": {
        "text": "Too cold through the glove."
      },
      "backgroundEvent4": {
        "text": "Maya"
      },
      "event8": {
        "text": "Because I touched it."
      },
      "event6": {
        "text": "No, don't say my name."
      },
      "event12": {
        "text": "Display woke up."
      },
      "event9": {
        "title": "POD CONTACT WAKE",
        "content": "Manual contact detected\nDisplay state: partial wake\nSuit registry ping returned\nRecovered ID fragment: NV-08\nWarning: occupant identity unresolved",
        "caption": "Manual contact wakes the pod display and returns suit fragment NV-08.",
        "message": "[POD CONTACT WAKE ARCHIVED TO DATA BANK]"
      },
      "event17": {
        "text": "NV-08."
      },
      "event11": {
        "text": "Noah's mark."
      },
      "event21": {
        "text": "Operator, you backed me."
      },
      "event23": {
        "text": "So stay with me now."
      },
      "event13": {
        "text": "Tell me this isn't what I think it is."
      },
      "event28": {
        "text": "Hale is still on the line."
      },
      "event30": {
        "text": "Barely."
      }
    },
    "e08_n07_identity": {
      "event1": {
        "text": "Three facts."
      },
      "event3": {
        "text": "Manifest says unknown occupant."
      },
      "event5": {
        "text": "Suit fragment says NV-08."
      },
      "event7": {
        "text": "Life signs say alive."
      },
      "event10": {
        "text": "I don't need a puzzle for this."
      },
      "event12": {
        "text": "Noah used NV-08 on everything."
      },
      "event16": {
        "text": "Anxiety with stationery."
      },
      "event18": {
        "text": "Cable caps."
      },
      "event14": {
        "text": "Ration boxes."
      },
      "event19": {
        "text": "I miss that idiot."
      },
      "choice0": {
        "text": "PULL VOSS DEATH RECORD."
      },
      "choice1": {
        "text": "LISTEN THROUGH THE POD HULL."
      }
    },
    "e08_n08_death_record": {
      "event1": {
        "text": "I found the record."
      },
      "event2": {
        "title": "DEATH RECORD: NOAH VOSS",
        "content": "Subject: Noah Voss\nStatus: deceased\nReported Date: before Incident Alpha\nBody Recovery: confirmed by Engineering Lead\nWitness: Ethan Hale\nConflict: active biometric signal currently transmitting under suit ID NV-08",
        "caption": "Recovered death record directly conflicts with pod telemetry.",
        "message": "[DEATH RECORD: NOAH VOSS ARCHIVED TO DATA BANK]"
      },
      "event4": {
        "text": "Voss is dead."
      },
      "event6": {
        "text": "I saw the body."
      },
      "event11": {
        "text": "Frost on the visor."
      },
      "event13": {
        "text": "Suit seal locked."
      },
      "event8": {
        "text": "Hand curled like he was about to argue."
      },
      "event10": {
        "text": "He usually was."
      },
      "event20": {
        "text": "Bad engineer."
      },
      "event14": {
        "text": "Good person."
      },
      "event16": {
        "text": "Most days I needed that one more."
      }
    },
    "e08_n08_listen": {
      "event1": {
        "text": "I'm putting the mic against the hull."
      },
      "event3": {
        "text": "No one breathe dramatically. That includes me."
      },
      "event5": {
        "text": "I need silence for this. Real silence."
      },
      "event6": {
        "message": "[MAYA IS LISTENING]"
      }
    },
    "e08_r08_listen_return": {
      "event0": {
        "text": "NOT THE SUIT"
      },
      "event2": {
        "text": "NOT THE BODY"
      },
      "event4": {
        "text": "That was not mechanical."
      },
      "event6": {
        "text": "Maya, step back."
      },
      "event8": {
        "text": "Like stepping back saved anyone here."
      },
      "event12": {
        "text": "You keep saying that."
      }
    },
    "e08_n09_decision": {
      "event1": {
        "text": "Life support is dropping."
      },
      "event3": {
        "text": "Twenty-three became twenty-one while we argued."
      },
      "event5": {
        "text": "I hate that sentence."
      },
      "event8": {
        "text": "For real."
      },
      "event10": {
        "text": "Or again."
      },
      "event14": {
        "text": "Open it wrong and we risk depressurization."
      },
      "event7": {
        "text": "Or wake whatever signal is riding it."
      },
      "event18": {
        "text": "No plans."
      },
      "event9": {
        "text": "Decision."
      },
      "event22": {
        "text": "Fast rescue means hatch now."
      },
      "event24": {
        "text": "Controlled breach means clamp first."
      },
      "event26": {
        "text": "And yes, Hale, I know what you want."
      },
      "choice0": {
        "text": "FAST RESCUE: OPEN THE HATCH NOW."
      },
      "choice1": {
        "text": "CONTROLLED BREACH: CLAMP THEN OPEN."
      }
    },
    "e08_n10_fast_rescue": {
      "event1": {
        "text": "Fast rescue."
      },
      "event3": {
        "text": "Good. Terrible. Good."
      },
      "event5": {
        "text": "I'm releasing the manual latch and pulling the occupant line."
      },
      "event6": {
        "message": "[MAYA IS OPENING POD]"
      }
    },
    "e08_r10_fast_return": {
      "event2": {
        "text": "Hatch released."
      },
      "event4": {
        "text": "Shoulder hit the frame."
      },
      "event6": {
        "text": "I'm fine."
      },
      "event11": {
        "text": "No."
      },
      "event13": {
        "text": "Functional."
      },
      "event15": {
        "text": "Different category."
      },
      "event8": {
        "text": "That was too quick."
      },
      "event19": {
        "text": "She could have lost the seal."
      },
      "event10": {
        "text": "But I didn't."
      },
      "event12": {
        "text": "And someone inside just moved."
      },
      "event26": {
        "text": "If something comes through with him, that's on us."
      }
    },
    "e08_n10_controlled": {
      "event1": {
        "text": "Controlled breach."
      },
      "event3": {
        "text": "Thank you for choosing the option least likely to turn Maya into a cautionary diagram."
      },
      "event5": {
        "text": "I heard that."
      },
      "event7": {
        "text": "I'm anchoring the hatch while he calculates pressure release."
      },
      "event8": {
        "message": "[MAYA IS CLAMPING POD]"
      }
    },
    "e08_r10_controlled_return": {
      "event1": {
        "text": "Seal clamped."
      },
      "event3": {
        "text": "Mostly."
      },
      "event5": {
        "text": "You can admit fear."
      },
      "event7": {
        "text": "You first."
      },
      "event9": {
        "text": "Absolutely not."
      },
      "event11": {
        "text": "Opening now."
      },
      "event18": {
        "text": "Operator, this bought us control."
      },
      "event20": {
        "text": "Not comfort."
      },
      "event23": {
        "text": "The clamps bought control."
      },
      "event25": {
        "text": "They also bought delay."
      }
    },
    "e08_n11_inside": {
      "event1": {
        "text": "The hatch is open."
      },
      "event4": {
        "text": "There's frost everywhere."
      },
      "event6": {
        "text": "I see a suit."
      },
      "event9": {
        "text": "NV-08 on the chest."
      },
      "event11": {
        "text": "Helmet is cracked."
      },
      "event13": {
        "text": "Not enough to kill him if the pod kept pressure, but enough to make the universe feel personal."
      },
      "backgroundEvent12": {
        "text": "Maya"
      },
      "event14": {
        "text": "The faceplate is fogged from the inside."
      },
      "event16": {
        "text": "Inside means breathing."
      },
      "event18": {
        "text": "Inside means I have to look."
      },
      "choice0": {
        "text": "CLEAR THE FACEPLATE."
      },
      "choice1": {
        "text": "CHECK WRIST BIOMETRICS FIRST."
      }
    },
    "e08_n12_faceplate": {
      "event1": {
        "text": "Clearing the faceplate."
      },
      "event4": {
        "text": "No."
      },
      "event6": {
        "text": "No, no, no."
      },
      "event8": {
        "text": "It looks like Noah."
      },
      "event10": {
        "text": "Maya, step away from the pod."
      },
      "event12": {
        "text": "Don't you dare make this smaller than it is."
      },
      "event14": {
        "text": "His eyes are moving under the lids."
      },
      "event15": {
        "text": "where"
      },
      "event17": {
        "text": "He heard that."
      }
    },
    "e08_n12_biometrics": {
      "event1": {
        "text": "Checking wrist biometrics first."
      },
      "event3": {
        "text": "Thank you for making me do the thing that doesn't involve staring at a possibly dead friend's face."
      },
      "event4": {
        "title": "POD BIOMETRIC WRIST TRACE",
        "content": "Suit ID: NV-08\nHeartbeat: active irregular\nNeural response: suppressed\nBody temperature: survivable\nIdentity confidence: 61% Noah Voss\nWarning: memory imprint contamination detected",
        "caption": "Wrist biometrics suggest Noah Voss but warn of memory imprint contamination.",
        "message": "[POD BIOMETRIC WRIST TRACE ARCHIVED TO DATA BANK]"
      },
      "event6": {
        "text": "Identity confidence sixty-one percent."
      },
      "event8": {
        "text": "That's not enough to celebrate. It is absolutely enough to ruin me."
      },
      "event10": {
        "text": "Memory imprint contamination?"
      },
      "event12": {
        "text": "There it is. The phrase that makes everything worse."
      }
    },
    "e08_n13_irreversible": {
      "event1": {
        "text": "Listen carefully."
      },
      "event3": {
        "text": "the signal may come with him."
      },
      "event7": {
        "text": "Translation?"
      },
      "event9": {
        "text": "Seal the pod. Keep him alive. Keep him trapped."
      },
      "event5": {
        "text": "And keep broadcasting to 7.14."
      },
      "event15": {
        "text": "Save the body. Risk the signal."
      },
      "event12": {
        "text": "Operator."
      },
      "event14": {
        "text": "Make the call before I make the emotional one."
      },
      "choice0": {
        "text": "EXTRACT NOAH NOW."
      },
      "choice1": {
        "text": "SEAL POD AND KEEP HIM ALIVE."
      }
    },
    "e08_n14_extract": {
      "event1": {
        "text": "Extracting him."
      },
      "event3": {
        "text": "I'm going to be furious when you wake up."
      },
      "event7": {
        "text": "Umbilicals first."
      },
      "event9": {
        "text": "Cradle release."
      },
      "event5": {
        "text": "Then I pull him out."
      },
      "event13": {
        "text": "Operator, you chose this."
      },
      "event15": {
        "text": "Stay with me."
      },
      "event6": {
        "message": "[MAYA IS EXTRACTING NOAH]"
      }
    },
    "e08_r14_extract_return": {
      "event2": {
        "text": "He's out."
      },
      "event4": {
        "text": "Breathing."
      },
      "event7": {
        "text": "No."
      },
      "event9": {
        "text": "Wait."
      },
      "event11": {
        "text": "Still breathing."
      },
      "event13": {
        "text": "I almost dropped him."
      },
      "event15": {
        "text": "The pod screamed through the comms."
      },
      "event17": {
        "text": "Not sound."
      },
      "event19": {
        "text": "Signal."
      },
      "event21": {
        "text": "Hale is yelling."
      },
      "event23": {
        "text": "I can't process the whole sentence."
      },
      "event25": {
        "text": "Noah's hand moved."
      },
      "event27": {
        "text": "I need to get him inside."
      },
      "event30": {
        "text": "Operator, you chose a body over a clean signal."
      },
      "event32": {
        "text": "I hope you are right."
      }
    },
    "e08_n14_seal": {
      "event1": {
        "text": "Sealing the pod."
      },
      "event4": {
        "text": "I hate this."
      },
      "event6": {
        "text": "Not you."
      },
      "event8": {
        "text": "This."
      },
      "event10": {
        "text": "The whole impossible shape of it."
      },
      "event12": {
        "text": "Life support line stays active."
      },
      "event14": {
        "text": "Beacon stays open."
      },
      "event16": {
        "text": "Noah stays inside."
      },
      "event18": {
        "text": "Operator..."
      },
      "event20": {
        "text": "I will remember this one."
      },
      "event21": {
        "message": "[MAYA IS SEALING POD]"
      }
    },
    "e08_r14_seal_return": {
      "event1": {
        "text": "Seal took."
      },
      "event3": {
        "text": "Life support stopped falling."
      },
      "event5": {
        "text": "Seventeen percent."
      },
      "event7": {
        "text": "Not enough."
      },
      "event9": {
        "text": "Enough."
      },
      "event12": {
        "text": "Noah is still inside."
      },
      "event14": {
        "text": "I can see his breath fogging the faceplate."
      },
      "event16": {
        "text": "I know why we did it."
      },
      "event18": {
        "text": "Do not ask me to like it."
      },
      "event20": {
        "text": "Hale is relieved."
      },
      "event22": {
        "text": "That makes me want to break something."
      },
      "event25": {
        "text": "Operator, you chose a sealed door over a living hand."
      },
      "event27": {
        "text": "I know why."
      },
      "event29": {
        "text": "That does not make it smaller."
      }
    },
    "e08_n15_exit_extract": {
      "event1": {
        "text": "I'm hauling him back through the tether."
      },
      "event3": {
        "text": "He is heavier than he looks. Or I am more tired than I want to admit."
      },
      "backgroundEvent4": {
        "text": "not alone"
      },
      "event6": {
        "text": "I need both hands. I'm moving now."
      },
      "event7": {
        "message": "[MAYA IS RETURNING WITH NOAH]"
      }
    },
    "e08_r15_extract_return": {
      "event2": {
        "text": "Back inside the relay spine."
      },
      "event4": {
        "text": "Noah is still breathing."
      },
      "event6": {
        "text": "Barely."
      },
      "event8": {
        "text": "His suit keeps pinging 7.14."
      },
      "event10": {
        "text": "Every ping makes the lights twitch."
      },
      "event12": {
        "text": "You saved him."
      },
      "event15": {
        "text": "Or brought something in with him."
      },
      "event17": {
        "text": "Both can be true."
      },
      "event19": {
        "text": "I hate both."
      },
      "choice0": {
        "text": "KEEP NOAH AWAKE."
      },
      "choice1": {
        "text": "LET NOAH REST AND MONITOR HIM."
      }
    },
    "e08_n15_exit_seal": {
      "event1": {
        "text": "I'm backing away from the pod."
      },
      "event3": {
        "text": "I keep expecting him to knock from inside."
      },
      "backgroundEvent4": {
        "text": "Maya"
      },
      "event6": {
        "text": "There. He did."
      },
      "event8": {
        "text": "One tap. Then two."
      },
      "event10": {
        "text": "Noah used to do that on bulkheads when he wanted attention."
      },
      "event12": {
        "text": "Or something in there knows that."
      },
      "event14": {
        "text": "I need to get out of the pod frame before I change my mind."
      },
      "event15": {
        "message": "[MAYA IS LEAVING POD AREA]"
      }
    },
    "e08_r15_seal_return": {
      "event1": {
        "text": "I'm back at the relay spine."
      },
      "event3": {
        "text": "Pod is still broadcasting."
      },
      "event5": {
        "text": "Weak."
      },
      "event7": {
        "text": "Steady."
      },
      "event9": {
        "text": "Like a pulse through a wall."
      },
      "event12": {
        "text": "I keep thinking I should have argued harder."
      },
      "event14": {
        "text": "Then I remember his life support stabilized."
      },
      "event16": {
        "text": "Then I hate both thoughts."
      }
    },
    "e08_n16_awake": {
      "event1": {
        "text": "Keeping him awake."
      },
      "event3": {
        "text": "Noah. Stay with me. Look at my hand if you can't look at my face."
      },
      "event5": {
        "text": "He's trying to speak."
      },
      "event6": {
        "text": "WHERE IS EVA"
      },
      "event9": {
        "text": "He said Eva."
      },
      "event11": {
        "text": "Hale just stopped breathing on the channel."
      },
      "event13": {
        "text": "I don't breathe."
      },
      "event15": {
        "text": "You know what I mean."
      }
    },
    "e08_n16_rest": {
      "event1": {
        "text": "Letting him rest."
      },
      "event3": {
        "text": "I hate that the right thing can look so much like abandoning someone."
      },
      "event5": {
        "text": "His pulse is ugly but present."
      },
      "event7": {
        "text": "He said one thing before his eyes closed again."
      },
      "event9": {
        "text": "EVA"
      },
      "event11": {
        "text": "Hale, why does that name make the signal colder?"
      }
    },
    "e08_n16_seal_final": {
      "event1": {
        "text": "We sealed him in."
      },
      "event3": {
        "text": "I keep repeating that because maybe if I say it enough, it becomes a strategy instead of a wound."
      },
      "event5": {
        "text": "The pod is alive. Noah is alive. The channel is not quiet."
      },
      "backgroundEvent6": {
        "text": "eva"
      },
      "event8": {
        "text": "There. That name again."
      },
      "event10": {
        "text": "Hale?"
      },
      "event12": {
        "text": "We need to find Eva Thorne."
      }
    },
    "e08_n17_final_extract": {
      "event1": {
        "text": "Noah is in the relay bay."
      },
      "event3": {
        "text": "Alive."
      },
      "event5": {
        "text": "Maybe."
      },
      "event7": {
        "text": "Not alone."
      },
      "event10": {
        "text": "7.14 is bleeding through every channel."
      },
      "event12": {
        "text": "Then we move before it learns the room."
      },
      "event14": {
        "text": "Operator, your call changed everything."
      },
      "event16": {
        "text": "Do not forget that just because we survived it."
      },
      "choice0": {
        "text": "MOVE NOAH TO A SAFE ZONE."
      },
      "choice1": {
        "text": "ASK ABOUT EVA NOW."
      }
    },
    "e08_n17_final_seal": {
      "event1": {
        "text": "Pod remains outside."
      },
      "event3": {
        "text": "Noah remains inside."
      },
      "event6": {
        "text": "Life support is holding."
      },
      "event8": {
        "text": "For now."
      },
      "event9": {
        "text": "still"
      },
      "event10": {
        "text": "breathing"
      },
      "event12": {
        "text": "I am going to hear that forever."
      },
      "event14": {
        "text": "Operator, we either find Eva now..."
      },
      "event16": {
        "text": "or we go back and admit what we left behind."
      },
      "choice0": {
        "text": "LEAVE THE POD AND FIND EVA."
      },
      "choice1": {
        "text": "KEEP THE POD CHANNEL OPEN."
      }
    }
  }
}
