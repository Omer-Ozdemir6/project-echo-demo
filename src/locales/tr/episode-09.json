{
  "episode_09": {
    "meta": {
      "title": "THE RESCUE — ECHO DIRECTOR'S CUT V9"
    },
    "e09_n01": {
      "event1": {
        "text": "Rescue junction."
      },
      "event3": {
        "text": "Like it doesn't want to be found."
      },
      "event5": {
        "text": "Life support is dropping."
      },
      "event12": {
        "text": "The pulse is right there on the display."
      },
      "event15": {
        "text": "I heard Noah in the last transmission."
      },
      "event8": {
        "text": "Or something wearing his voice."
      },
      "backgroundEvent18": {
        "text": "OPEN BEFORE HE STOPS"
      },
      "backgroundEvent19": {
        "text": "THE POD KNOWS HIM"
      },
      "backgroundEvent9": {
        "text": "HE COUNTS EVERY DELAY"
      },
      "event11": {
        "text": "Nobody touches that hatch until we know what's moving inside it."
      },
      "event13": {
        "text": "That's easy for the dead engineer to say."
      },
      "event26": {
        "text": "Maya."
      },
      "event28": {
        "text": "No."
      },
      "event30": {
        "text": "Not yet."
      },
      "choice0": {
        "text": "STABILIZE THE BEACON FIRST."
      },
      "choice1": {
        "text": "MOVE TOWARD THE POD NOW."
      }
    },
    "e09_n02_stabilize": {
      "event1": {
        "text": "Okay. Beacon first."
      },
      "event3": {
        "text": "Things that don't pretend to be dead friends."
      },
      "event5": {
        "text": "Hale's filtering the beacon. I'm staying where the floor still agrees with me."
      },
      "event7": {
        "text": "If I move, the beacon starts lying again."
      },
      "event9": {
        "text": "Numbers. Please be normal."
      },
      "backgroundEvent17": {
        "text": "The relay pack is buzzing against my spine."
      },
      "backgroundEvent18": {
        "text": "Not pain. Just deeply annoying."
      },
      "event8": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r02_stabilize_return": {
      "event1": {
        "text": "Okay. It held."
      },
      "event3": {
        "text": "Pod is still moving."
      },
      "event5": {
        "text": "Cleaner. Not safe."
      },
      "event8": {
        "text": "Signal's cleaner."
      },
      "event12": {
        "text": "At least now it's lying in a straight line."
      },
      "event7": {
        "text": "I hate that I can hear it better now."
      },
      "event19": {
        "text": "You bought us a cleaner line."
      },
      "event21": {
        "text": "I can also hear the wrong thing better now."
      }
    },
    "e09_n02_move": {
      "event1": {
        "text": "Moving."
      },
      "event3": {
        "text": "Visual range. Fast."
      },
      "event5": {
        "text": "You're rushing."
      },
      "event7": {
        "text": "Someone might be dying."
      },
      "event9": {
        "text": "That is not a plan."
      },
      "event11": {
        "text": "It's a direction.",
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      },
      "backgroundEvent8": {
        "text": "HE HEARS YOU"
      },
      "event14": {
        "text": "Clip's fighting me. Give me a second."
      },
      "event10": {
        "text": "Map's twitching. I'm moving before it lies again."
      },
      "event18": {
        "text": "If this was reckless, remember you picked it."
      }
    },
    "e09_r02_move_return": {
      "event2": {
        "text": "I see it."
      },
      "event4": {
        "text": "Pod is closer than the map said."
      },
      "event7": {
        "text": "That should not be possible."
      },
      "event6": {
        "text": "Beacon dragged across my display while I moved."
      },
      "event11": {
        "text": "Like the pod corrected where I thought it was."
      },
      "event13": {
        "text": "So."
      },
      "event15": {
        "text": "Map is wrong."
      },
      "event8": {
        "text": "Or the pod moved toward me."
      },
      "event19": {
        "text": "I don't love either answer."
      },
      "event22": {
        "text": "Fast got us eyes on it."
      },
      "event24": {
        "text": "Fast also let it see me back."
      }
    },
    "e09_n03_route": {
      "event0": {
        "title": "RESCUE ROUTE MAP",
        "content": "ROUTE A: Short route through exposed radiation corridor. Arrival fast. Crew risk severe. Pod risk moderate.\n\nROUTE B: Long route through maintenance spine. Arrival delayed. Crew risk moderate. Pod risk severe.",
        "caption": "Recovered rescue route analysis. Both routes carry consequences.",
        "message": "[RESCUE ROUTE MAP ARCHIVED TO DATA BANK]"
      },
      "event2": {
        "text": "Two paths."
      },
      "event4": {
        "text": "Route A gets me there fast."
      },
      "event9": {
        "text": "My suit takes the radiation. My body gets the invoice."
      },
      "event6": {
        "text": "Route B keeps me safer."
      },
      "event13": {
        "text": "The pod loses time."
      },
      "event16": {
        "text": "If you picked caution before, this is where it gets expensive."
      },
      "event18": {
        "text": "If you like heroic stupidity, Route A is waving at you."
      },
      "event8": {
        "text": "Pick the sin you can live with."
      },
      "choice0": {
        "text": "ROUTE A — FAST / DANGEROUS."
      },
      "choice1": {
        "text": "ROUTE B — SAFER / SLOWER."
      }
    },
    "e09_n04_route_a": {
      "event1": {
        "text": "Fast and dangerous. Great."
      },
      "event3": {
        "text": "Corridor ahead. Radiation tags on both walls."
      },
      "event7": {
        "text": "Wasn't planning a picnic, Ethan."
      },
      "event9": {
        "text": "Rude."
      },
      "event5": {
        "text": "Do not stop in the exposed section."
      },
      "backgroundEvent8": {
        "text": "LESS AIR"
      },
      "event16": {
        "text": "Going quiet."
      },
      "event10": {
        "text": "No talking. I need my legs to believe me."
      },
      "event11": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r04_route_a_return": {
      "event2": {
        "text": "Okay."
      },
      "event5": {
        "text": "Give me a second."
      },
      "event8": {
        "text": "If my hair falls out, I'm blaming you."
      },
      "event4": {
        "text": "Suit alarm is screaming."
      },
      "event12": {
        "text": "Pretty sure I can taste metal."
      },
      "event6": {
        "text": "Corridor hummed through my teeth."
      },
      "event16": {
        "text": "Didn't know a place could do that."
      },
      "event18": {
        "text": "Closer now."
      },
      "event22": {
        "text": "Emotionally."
      },
      "event24": {
        "text": "Not legally."
      },
      "event27": {
        "text": "Suit logged exposure."
      },
      "event29": {
        "text": "That's not a mood. That's a record."
      }
    },
    "e09_n04_route_b": {
      "event1": {
        "text": "Maintenance spine it is."
      },
      "event3": {
        "text": "Safer for me."
      },
      "event5": {
        "text": "This is the sensible path."
      },
      "event7": {
        "text": "Sensible is a nice word for slow when someone is suffocating."
      },
      "backgroundEvent8": {
        "text": "HE COUNTS DELAY"
      },
      "event12": {
        "text": "Most of this is crawling. Lovely."
      },
      "event10": {
        "text": "Don't expect charm when I get back."
      },
      "event11": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r04_route_b_return": {
      "event1": {
        "text": "I'm at the pod."
      },
      "event3": {
        "text": "Found older boot marks in the dust."
      },
      "event5": {
        "text": "One set stops halfway."
      },
      "event8": {
        "text": "But no radiation alarm."
      },
      "event12": {
        "text": "Someone used this route before us."
      },
      "event16": {
        "text": "Turns back."
      },
      "event19": {
        "text": "Comforting in exactly no way."
      },
      "event21": {
        "text": "I got here safer."
      },
      "event23": {
        "text": "The pod lost time."
      },
      "event7": {
        "text": "Both facts are sitting in my chest."
      },
      "event28": {
        "text": "We saved my skin."
      },
      "event30": {
        "text": "We spent his air."
      }
    },
    "e09_n05_pod_exterior": {
      "event1": {
        "text": "At the pod."
      },
      "event3": {
        "text": "Hull is frosted from the inside."
      },
      "event6": {
        "text": "Wait."
      },
      "event8": {
        "text": "Memory leak."
      },
      "event11": {
        "text": "No."
      },
      "event13": {
        "text": "Just my reflection."
      },
      "event15": {
        "text": "I think."
      },
      "event5": {
        "text": "Noah used to draw faces in condensation."
      },
      "event19": {
        "text": "Terrible faces."
      },
      "event21": {
        "text": "Potatoes with opinions."
      },
      "event24": {
        "text": "Sorry."
      },
      "event28": {
        "text": "Human version."
      },
      "event9": {
        "title": "POD EXTERIOR SCAN",
        "content": "Hull Temperature: below operational range\nSeal Pressure: unstable\nInterior Motion: intermittent\nAudio Contamination: rising\nManual Override: possible\nWarning: signal distortion resembles recursive voice fold",
        "caption": "Exterior scan of the pod. The pod is physically reachable but unstable.",
        "message": "[POD EXTERIOR SCAN ARCHIVED TO DATA BANK]"
      },
      "backgroundEvent10": {
        "text": "Do not open it yet."
      },
      "backgroundEvent11": {
        "text": "SHE OPENED ONCE"
      },
      "choice0": {
        "text": "SECURE THE POD BEFORE TOUCHING THE HATCH."
      },
      "choice1": {
        "text": "INSPECT THE HATCH NOW."
      }
    },
    "e09_n06_secure": {
      "event1": {
        "text": "Anchor first."
      },
      "event3": {
        "text": "If it moves, I move with it."
      },
      "event5": {
        "text": "That is both reassuring and horrifying."
      },
      "event6": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r06_secure_return": {
      "event1": {
        "text": "Anchor caught."
      },
      "event3": {
        "text": "Pod stopped pulling."
      },
      "event5": {
        "text": "I wish that sentence felt less alive."
      },
      "event8": {
        "text": "Line keeps twitching."
      },
      "event7": {
        "text": "Like something inside answers the beacon."
      },
      "event12": {
        "text": "Still."
      },
      "event14": {
        "text": "Good call."
      },
      "event16": {
        "text": "Don't get smug."
      },
      "event19": {
        "text": "Anchor makes the hatch less stupid."
      },
      "event21": {
        "text": "Still stupid. Just less."
      }
    },
    "e09_n06_hatch": {
      "event1": {
        "text": "Hatch now."
      },
      "event3": {
        "text": "Pod's still drifting."
      },
      "event5": {
        "text": "Maya, back off."
      },
      "event9": {
        "text": "The pod is still moving.",
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      },
      "backgroundEvent6": {
        "text": "HE HEARS YOU"
      },
      "event12": {
        "text": "One hand on the rail."
      },
      "event8": {
        "text": "Other hand on the hatch."
      },
      "event16": {
        "text": "If this goes badly, you picked urgency."
      }
    },
    "e09_r06_hatch_return": {
      "event2": {
        "text": "It shifted."
      },
      "event4": {
        "text": "I hit the rail."
      },
      "event6": {
        "text": "Shoulder disagrees."
      },
      "event9": {
        "text": "Lie."
      },
      "event13": {
        "text": "Still attached."
      },
      "event15": {
        "text": "Hatch is still reachable."
      },
      "event8": {
        "text": "Whole frame is carrying motion through it."
      },
      "event19": {
        "text": "I can work with that."
      },
      "event21": {
        "text": "I don't have to like it."
      },
      "event24": {
        "text": "Shoulder's going to remember this."
      },
      "event26": {
        "text": "So will I."
      }
    },
    "e09_n07_hale_reveal": {
      "event1": {
        "text": "Before you touch that override, I need to say something."
      },
      "event3": {
        "text": "I have seen this pod before."
      },
      "event5": {
        "text": "Before Alpha."
      },
      "event8": {
        "text": "It was empty."
      },
      "event10": {
        "text": "No body."
      },
      "event12": {
        "text": "No suit."
      },
      "event14": {
        "text": "No blood."
      },
      "event7": {
        "text": "Just frost inside the glass."
      },
      "event9": {
        "text": "You opened it?"
      },
      "event11": {
        "text": "I opened it."
      },
      "event13": {
        "text": "That is such an Ethan answer."
      },
      "backgroundEvent14": {
        "text": "ASK WHAT HE SEALED"
      },
      "backgroundEvent15": {
        "text": "I wish I were."
      },
      "event26": {
        "text": "Operator."
      },
      "event28": {
        "text": "If you trusted me before, trust me now."
      },
      "event30": {
        "text": "And if you didn't..."
      },
      "event32": {
        "text": "start now."
      },
      "choice0": {
        "text": "PULL HALE'S OLD POD LOG."
      },
      "choice1": {
        "text": "MAYA, STAY ON THE HATCH."
      }
    },
    "e09_n08_old_log": {
      "event0": {
        "title": "OLD POD ACCESS LOG",
        "content": "Access Event: Emergency Pod Manual Inspection\nTimestamp: Before Incident Alpha\nOperator: Ethan Hale\nPod State: empty\nInterior Residue: frost / no biological matter detected\nSeal Reclosure: completed manually\nCurrent Conflict: active motion and biometrics now detected inside same pod",
        "caption": "Recovered old access log. Hale previously opened the pod before Alpha.",
        "message": "[OLD POD ACCESS LOG ARCHIVED TO DATA BANK]"
      },
      "event1": {
        "title": "HALE RECLOSURE NOTE",
        "content": "ENGINEERING NOTE — ETHAN HALE\nManual reclosure completed.\nPod interior reported empty.\nFrost pattern inconsistent with vacuum exposure.\nAudio anomaly present after seal closure.\nPersonal note: I should have logged the voice.",
        "caption": "Hale's old pod reclosure note. It confirms the pod was closed again after an unexplained voice anomaly.",
        "message": "[HALE RECLOSURE NOTE ARCHIVED TO DATA BANK]"
      },
      "event2": {
        "text": "The log backs him up."
      },
      "event4": {
        "text": "I hate when a bad answer becomes documented."
      },
      "event6": {
        "text": "Empty before Alpha."
      },
      "event9": {
        "text": "Moving."
      },
      "event8": {
        "text": "So either something got in..."
      },
      "event10": {
        "text": "Or something was always there."
      },
      "event15": {
        "text": "And the system learned not to see it."
      },
      "event17": {
        "text": "I hate your sentences."
      },
      "event20": {
        "text": "You made him prove it."
      },
      "event22": {
        "text": "Good. I needed something that wasn't just his voice."
      }
    },
    "e09_n08_focus_hatch": {
      "event1": {
        "text": "Staying on the hatch."
      },
      "event3": {
        "text": "I know Hale wants records."
      },
      "event5": {
        "text": "Whatever is breathing in there is real enough for the pod to keep it alive."
      },
      "event8": {
        "text": "The hatch is real."
      },
      "event10": {
        "text": "The clock is real.",
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      },
      "backgroundEvent6": {
        "text": "Reality is exactly what this station edits best."
      },
      "backgroundEvent7": {
        "text": "Then keep talking while I work."
      },
      "event9": {
        "text": "Cover's off. Working the override."
      }
    },
    "e09_r08_focus_return": {
      "event1": {
        "text": "Handle's exposed."
      },
      "event3": {
        "text": "Looks old enough to hate me personally."
      },
      "event5": {
        "text": "Hatch clicked twice while I worked."
      },
      "event8": {
        "text": "Not metal settling."
      },
      "event10": {
        "text": "Deliberate."
      },
      "event12": {
        "text": "Like someone tapping back."
      },
      "event15": {
        "text": "We skipped proof for time."
      },
      "event17": {
        "text": "That choice is standing right here with us."
      }
    },
    "e09_n09_access_choice": {
      "event0": {
        "title": "POD ACCESS RISK REPORT",
        "content": "Interior Motion: detected\nSeal Pressure: unstable\nManual Override: required\nAudio Channel Contamination: rising\nExternal Voice Traffic: unauthorized\nRecommendation: choose access protocol before opening",
        "caption": "Recovered access risk report. The pod can be opened, but the audio channel is contaminated.",
        "message": "[POD ACCESS RISK REPORT ARCHIVED TO DATA BANK]"
      },
      "event2": {
        "text": "Override's ready."
      },
      "event4": {
        "text": "Pod keeps making pressure clicks."
      },
      "event6": {
        "text": "Like fingernails against glass."
      },
      "backgroundEvent5": {
        "text": "open"
      },
      "backgroundEvent8": {
        "text": "open"
      },
      "backgroundEvent9": {
        "text": "please"
      },
      "event11": {
        "text": "Operator."
      },
      "event7": {
        "text": "Decide how I open it."
      },
      "event15": {
        "text": "Careful means slower."
      },
      "event9": {
        "text": "Fast means I may not control what comes out."
      },
      "choice0": {
        "text": "VENT PRESSURE, THEN OPEN."
      },
      "choice1": {
        "text": "FORCE THE OVERRIDE NOW."
      }
    },
    "e09_n10_vent": {
      "event1": {
        "text": "Venting first."
      },
      "event3": {
        "text": "That buys control."
      },
      "event5": {
        "text": "Costs time."
      },
      "backgroundEvent6": {
        "text": "cold"
      },
      "event8": {
        "text": "Pressure's bleeding off the seal."
      },
      "event10": {
        "text": "Valve wants to jump. I have to hold it."
      },
      "event9": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r10_vent_return": {
      "event1": {
        "text": "Pressure stopped fighting me."
      },
      "event3": {
        "text": "Voice got weaker during venting."
      },
      "event8": {
        "text": "Don't know if that's good."
      },
      "event5": {
        "text": "Or monstrous."
      },
      "event12": {
        "text": "Hatch is safer now."
      },
      "event7": {
        "text": "Thing inside sounds less human."
      },
      "event17": {
        "text": "Controlled doesn't mean kind."
      },
      "event19": {
        "text": "It just means we know which damage we chose."
      }
    },
    "e09_n10_force": {
      "event1": {
        "text": "Forcing it."
      },
      "event3": {
        "text": "Maya, no—"
      },
      "backgroundEvent4": {
        "text": "thank you"
      },
      "event6": {
        "text": "Do not thank me yet."
      },
      "event8": {
        "text": "Pulling release."
      },
      "event9": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r10_force_return": {
      "event0": {
        "message": "[SIGNAL DROP]",
        "restoreMessage": "[SIGNAL RESTORED]"
      },
      "event2": {
        "text": "Seal punched back."
      },
      "event4": {
        "text": "Something hit the inside of the hatch."
      },
      "event6": {
        "text": "I heard it through my gloves."
      },
      "event9": {
        "text": "No."
      },
      "event11": {
        "text": "Felt it."
      },
      "event13": {
        "text": "Worse."
      },
      "event15": {
        "text": "Pod wants open now."
      },
      "event8": {
        "text": "I can feel it fighting the latch."
      },
      "event19": {
        "text": "Hale is going to remember this."
      },
      "event21": {
        "text": "So am I."
      },
      "event24": {
        "text": "Fast worked."
      },
      "event26": {
        "text": "Fast also woke the whole damn thing up."
      }
    },
    "e09_n11_final_decision": {
      "event1": {
        "text": "Last chance."
      },
      "event3": {
        "text": "you commit to whatever is inside."
      },
      "event7": {
        "text": "I hate both options."
      },
      "event5": {
        "text": "you may leave a person to die."
      },
      "event13": {
        "text": "Good."
      },
      "event9": {
        "text": "That means you understand them."
      },
      "backgroundEvent16": {
        "text": "SHE OPENED ONCE"
      },
      "backgroundEvent10": {
        "text": "please"
      },
      "event19": {
        "text": "Operator."
      },
      "event21": {
        "text": "Whatever you choose, I carry it."
      },
      "choice0": {
        "text": "OPEN THE POD."
      },
      "choice1": {
        "text": "ABORT THE RESCUE."
      }
    },
    "e09_open_branch": {
      "event1": {
        "text": "Opening."
      },
      "event3": {
        "text": "Air's mixing."
      },
      "event5": {
        "text": "Keep your face away from the seam."
      },
      "event7": {
        "text": "There's someone inside."
      },
      "backgroundEvent8": {
        "text": "thank you"
      },
      "event10": {
        "text": "Final lock. Come on."
      },
      "event11": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r_open_branch_return": {
      "event2": {
        "text": "There's a glove."
      },
      "event5": {
        "text": "No."
      },
      "event7": {
        "text": "Wait."
      },
      "event9": {
        "text": "I know that glove."
      },
      "event4": {
        "text": "NV on the wrist."
      },
      "event13": {
        "text": "If this is a trap..."
      },
      "event6": {
        "text": "it knows exactly which dead man to wear."
      },
      "event8": {
        "text": "He's breathing."
      },
      "event19": {
        "text": "Or the pod is making him look like he is."
      },
      "event21": {
        "text": "Operator."
      },
      "event23": {
        "text": "You opened it."
      },
      "event25": {
        "text": "Episode ten starts with that."
      },
      "event28": {
        "text": "If that's Noah, we saved him."
      },
      "event30": {
        "text": "If it isn't... we opened the door for it."
      },
      "choice0": {
        "text": "KEEP THE POD OPEN."
      },
      "choice1": {
        "text": "STABILIZE THE OPEN POD FIRST."
      }
    },
    "e09_abort_branch": {
      "event1": {
        "text": "Aborting."
      },
      "event4": {
        "text": "I hate you a little right now."
      },
      "event6": {
        "text": "But right now."
      },
      "event8": {
        "text": "Maybe not fairly."
      },
      "backgroundEvent7": {
        "text": "you promised"
      },
      "backgroundEvent8": {
        "text": "Maya, step away from the hatch."
      },
      "event10": {
        "text": "I'm trying."
      },
      "event12": {
        "text": "Need to pull away before the beacon talks me back into this."
      },
      "event13": {
        "message": "[MAYA SIGNAL TEMPORARILY LOW]"
      }
    },
    "e09_r_abort_branch_return": {
      "event1": {
        "text": "I'm away."
      },
      "event4": {
        "text": "No."
      },
      "event6": {
        "text": "Not clear."
      },
      "event8": {
        "text": "Away."
      },
      "event10": {
        "text": "Different thing."
      },
      "event3": {
        "text": "Beacon is still following us."
      },
      "event5": {
        "text": "That feels like an answer we didn't ask for."
      },
      "event16": {
        "text": "I can hear it clicking through the line."
      },
      "event18": {
        "text": "One tap."
      },
      "event20": {
        "text": "Two taps."
      },
      "event7": {
        "text": "Like Noah used to do."
      },
      "event24": {
        "text": "If we survive the next room, I am going to be angry there too."
      },
      "event27": {
        "text": "If Noah is in there, he heard us leave."
      },
      "event29": {
        "text": "I need you to understand that."
      },
      "choice0": {
        "text": "TRACK THE BEACON."
      },
      "choice1": {
        "text": "REOPEN RESCUE CHANNEL."
      }
    }
  }
}
