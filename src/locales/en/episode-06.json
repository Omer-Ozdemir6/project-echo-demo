    "e06_n20": {
      "event0": {
        "text": "[IDENTITY RECONSTRUCTED]"
      },
      "event1": {
        "title": "NOAH VOSS",
        "content": "NOAH VOSS\nROLE: COMMUNICATIONS SPECIALIST\nCLEARANCE LEVEL: OMEGA\nSTATUS: UNKNOWN\nTRANSFER STATUS: DENIED\nMEMORY INDEX: SUPPRESSED\nLAST KNOWN SIGNAL: 7.14 EMERGENCY CARRIER\nNOTE: SUBJECT RECORD RESTORED BY EXTERNAL OPERATOR INPUT",
        "caption": "Restored crew profile for the erased seventh crew member.",
        "message": "[NOAH VOSS ARCHIVED TO DATA BANK]"
      },
      "event3": {
        "text": "Nobody says anything for a second."
      },
      "event5": {
        "text": "Not signal loss."
      },
      "event7": {
        "text": "Worse."
      },
      "event9": {
        "text": "A deleted man just got his name back."
      },
      "event12": {
        "text": "I do not know whether to be relieved or furious."
      },
      "event14": {
        "text": "Choosing both."
      }
    },
    "e06_n21": {
      "event1": {
        "text": "Noah Voss."
      },
      "event3": {
        "text": "Communications."
      },
      "event6": {
        "text": "The first erased person was the one meant to keep people talking."
      },
      "event8": {
        "text": "That is not irony."
      },
      "event10": {
        "text": "That is cruelty with paperwork."
      },
      "event13": {
        "text": "Transfer record is still locked behind the profile."
      },
      "event15": {
        "text": "Or we let the carrier answer now."
      },
      "event17": {
        "text": "I hate that both feel urgent."
      },
      "choice0": {
        "text": "PULL THE TRANSFER RECORD."
      },
      "choice1": {
        "text": "LET NOAH SPEAK."
      }
