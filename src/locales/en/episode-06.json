    "e06_n01": {
      "event1": {
        "text": "Operator."
      },
      "event4": {
        "text": "Behind the relay console."
      },
      "event6": {
        "text": "Access spine is tighter than promised."
      },
      "event9": {
        "text": "My shoulder is learning new shapes."
      },
      "event11": {
        "text": "Smells like hot plastic."
      },
      "event13": {
        "text": "And old dust."
      },
      "event15": {
        "text": "And something I am not naming yet."
      },
      "backgroundEvent16": {
        "text": "YOU FOUND THE EMPTY PLACE."
      },
      "event19": {
        "text": "Noah said you already saw his name."
      },
      "event21": {
        "text": "If that is true, it is in records we touched before."
      },
      "event24": {
        "text": "Also."
      },
      "event26": {
        "text": "About yesterday."
      },
      "event28": {
        "text": "If you asked me what I did..."
      },
      "event31": {
        "text": "I remember."
      },
      "event33": {
        "text": "I am still helping you."
      },
      "event35": {
        "text": "That is not forgiveness."
      },
      "event38": {
        "text": "Memory index is three junctions ahead."
      },
      "event40": {
        "text": "Call the route."
      },
      "choice0": {
        "text": "TAKE THE MAIN CORRIDOR."
      },
      "choice1": {
        "text": "USE THE SERVICE CRAWL."
      }
    },
    "e06_n02_main": {
      "event1": {
        "text": "Main corridor."
      },
      "event3": {
        "text": "Fast."
      },
      "event5": {
        "text": "Exposed."
      },
      "event8": {
        "text": "Floor plates are buckled."
      },
      "event10": {
        "text": "I am stepping over them."
      },
      "backgroundEvent11": {
        "text": "Wall clicked when I passed it."
      },
      "backgroundEvent12": {
        "text": "It clicked again when I stopped."
      },
      "event15": {
        "text": "Drone in the wall."
      },
      "event17": {
        "text": "No."
      },
      "event19": {
        "text": "Thrown into the wall."
      },
      "event21": {
        "text": "Casing split open."
      },
      "event23": {
        "text": "Could be a breadcrumb."
      },
      "event25": {
        "text": "Could be bait."
      },
      "choice0": {
        "text": "CHECK THE DRONE FIRST."
      },
      "choice1": {
        "text": "KEEP MOVING TO THE INDEX."
      }
    },
    "e06_n02_crawl": {
      "event1": {
        "text": "Service crawl."
      },
      "event3": {
        "text": "Low ceiling."
      },
      "event5": {
        "text": "Narrow walls."
      },
      "event7": {
        "text": "Knees are already filing a complaint."
      },
      "event10": {
        "text": "Going in sideways."
      },
      "backgroundEvent11": {
        "text": "Cable brushed my neck."
      },
      "backgroundEvent12": {
        "text": "I did not make a noise. Legally."
      },
      "event14": {
        "text": "Old cable tags in here."
      },
      "event16": {
        "text": "Handwritten."
      },
      "event19": {
        "text": "Rivera hated handwriting on system labels."
      },
      "event21": {
        "text": "One says VOSS."
      },
      "event24": {
        "text": "Not a file."
      },
      "event26": {
        "text": "A path."
      },
      "event28": {
        "text": "That feels worse."
      },
      "choice0": {
        "text": "FOLLOW THE VOSS CABLE TAG."
      },
      "choice1": {
        "text": "IGNORE IT AND REACH THE INDEX."
      }
    },
    "e06_n03_drone": {
      "event1": {
        "text": "Hold on."
      },
      "event3": {
        "text": "The drone still has a diagnostic core."
      },
      "event5": {
        "text": "Casing is split."
      },
      "event7": {
        "text": "Forced open from outside."
      },
      "event10": {
        "text": "Something is tucked under the core."
      },
      "event12": {
        "text": "Route packet."
      },
      "event14": {
        "text": "That should not be here."
      },
      "event17": {
        "text": "I need both hands."
      },
      "event19": {
        "text": "If I tear the buffer, we lose it."
      },
      "event20": {
        "message": "[MAYA IS EXTRACTING CACHE]"
      }
    },
    "e06_n03_tag": {
      "event1": {
        "text": "Following the tag."
      },
      "event3": {
        "text": "It runs toward the index."
      },
      "event5": {
        "text": "Cut once."
      },
      "event7": {
        "text": "Spliced twice."
      },
      "event10": {
        "text": "Someone rerouted this by hand."
      },
      "event12": {
        "text": "Not a system cleanup."
      },
      "event14": {
        "text": "A person did this."
      },
      "event17": {
        "text": "Tag is stuck."
      },
      "event19": {
        "text": "Peeling it loose."
      },
      "event21": {
        "text": "Carefully."
      },
      "event22": {
        "message": "[MAYA IS RECOVERING TAG]"
      }
    },
    "e06_n03_move": {
      "event1": {
        "text": "No detours."
      },
      "event3": {
        "text": "Straight to the index."
      },
      "event6": {
        "text": "The station keeps offering little reasons to stop."
      },
      "event8": {
        "text": "Clues."
      },
      "event10": {
        "text": "Bait."
      },
      "event13": {
        "text": "Momentum wins."
      },
      "event15": {
        "text": "If that was stupid, remember I sounded decisive."
      },
      "event16": {
        "message": "[MAYA IS MOVING]"
      }
    },
    "e06_n04": {
      "event1": {
        "text": "Index hatch."
      },
      "event3": {
        "text": "Manual seal."
      },
      "event5": {
        "text": "Someone wanted this shut even if the station woke up."
      },
      "event8": {
        "text": "Handle is cold through the glove."
      },
      "event10": {
        "text": "Cold means pressure imbalance."
      },
      "event12": {
        "text": "Or bad news pretending to be a temperature."
      },
      "event14": {
        "text": "Force it, or scan first."
      },
      "choice0": {
        "text": "FORCE THE HATCH."
      },
      "choice1": {
        "text": "SCAN THE LOCK FIRST."
      }
    },
    "e06_n05_force": {
      "event1": {
        "text": "Forcing it."
      },
      "event3": {
        "text": "Bad idea."
      },
      "event5": {
        "text": "Your bad idea."
      },
      "event8": {
        "text": "Shoulder on frame."
      },
      "event10": {
        "text": "Count of three."
      },
      "event13": {
        "text": "Two."
      },
      "event16": {
        "text": "Ow."
      },
      "event18": {
        "text": "Open."
      }
    },
    "e06_n05_scan": {
      "event1": {
        "text": "Reader on the lock."
      },
      "event3": {
        "text": "Good call."
      },
      "event5": {
        "text": "Tamper loop under the latch."
      },
      "event8": {
        "text": "If I forced this, local cache would wipe."
      },
      "event10": {
        "text": "Not dramatic."
      },
      "event12": {
        "text": "Actual wipe."
      },
      "event15": {
        "text": "Bypassing the loop."
      },
      "event17": {
        "text": "Slowly."
      },
      "event19": {
        "text": "Trying to look calm for the machine."
      },
      "event21": {
        "text": "It bought the performance."
      }
    },
    "e06_n06": {
      "event1": {
        "text": "Index chamber."
      },
      "event3": {
        "text": "Rows of memory cores."
      },
      "event5": {
        "text": "Most are dark."
      },
      "event7": {
        "text": "One is blinking."
      },
      "event10": {
        "text": "Not bright."
      },
      "event12": {
        "text": "Like it is trying not to be noticed."
      },
      "event13": {
        "title": "CORRUPTED MANIFEST FRAGMENT",
        "content": "CREW MEMBER #07\nSTATUS: ERASED\nSURNAME: VOSS\nMEMORY INDEX: DAMAGED\nSOURCE CONFLICT: OFFICIAL MANIFEST DENIES ENTRY",
        "caption": "Partially recovered crew record from the personnel memory index.",
        "message": "[CORRUPTED MANIFEST FRAGMENT ARCHIVED TO DATA BANK]"
      },
      "event15": {
        "text": "Voss."
      },
      "event17": {
        "text": "I do not remember anyone named Voss on ECHO."
      },
      "event20": {
        "text": "That came out too easy."
      },
      "backgroundEvent21": {
        "text": "YOU REMEMBER THE MISSING SHAPE."
      }
    },
    "e06_n07": {
      "event1": {
        "text": "Stop there."
      },
      "event4": {
        "text": "Maya, hand off the core."
      },
      "event6": {
        "text": "Now."
      },
      "event9": {
        "text": "Names are keys in ECHO."
      },
      "event11": {
        "text": "Not labels."
      },
      "event13": {
        "text": "Keys."
      },
      "event15": {
        "text": "Some open doors."
      },
      "event17": {
        "text": "Some wake what was shut down."
      },
      "event20": {
        "text": "I know how that sounds."
      },
      "event22": {
        "text": "I also know I am scared."
      },
      "choice0": {
        "text": "MAKE HALE EXPLAIN."
      },
      "choice1": {
        "text": "HAVE MAYA KEEP WORKING."
      }
    },
    "e06_n08_hale": {
      "event1": {
        "text": "Transfer request."
      },
      "event3": {
        "text": "Noah Voss."
      },
      "event5": {
        "text": "Communications."
      },
      "event8": {
        "text": "Denied."
      },
      "event10": {
        "text": "Sealed."
      },
      "event12": {
        "text": "Omega clearance conflict."
      },
      "event15": {
        "text": "I asked about it."
      },
      "event17": {
        "text": "I remember asking."
      },
      "event19": {
        "text": "I do not remember the answer."
      },
      "event21": {
        "text": "That is the part I hate."
      }
    },
    "e06_n08_maya": {
      "event1": {
        "text": "Keeping my hand on it."
      },
      "event3": {
        "text": "Hale can panic in complete sentences."
      },
      "event6": {
        "text": "The core is getting warmer."
      },
      "event8": {
        "text": "Not burn-warm."
      },
      "event10": {
        "text": "Angry-warm."
      },
      "event13": {
        "text": "No response from him now."
      },
      "event15": {
        "text": "Either he hated the joke."
      },
      "event17": {
        "text": "Or he is actually afraid."
      },
      "event19": {
        "text": "I hate the second one more."
      }
    },
    "e06_n09": {
