      "event8": {
        "text": "Not dramatic shaking."
      },
      "event10": {
        "text": "Small-button betrayal shaking."
      },
      "event13": {
        "text": "Okay."
      },
      "event15": {
        "text": "Breathing."
      },
      "event17": {
