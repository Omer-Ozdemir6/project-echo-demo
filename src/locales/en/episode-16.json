    "e16_r04_signal": {
      "event1": {
        "text": "I'm back."
      },
      "event3": {
        "text": "Had to stop."
      },
      "event5": {
        "text": "I forgot my own voice for a second."
      },
      "event7": {
        "text": "I knew what I wanted to say."
      },
      "event9": {
        "text": "But it came out as someone else's breath."
      },
      "event11": {
        "text": "Signal trail is intact."
      },
      "event13": {
        "text": "I don't think I am."
      },
      "event15": {
        "text": "EVA OPENED IT ONCE."
      }
    },
    "e16_n04_memory": {
      "event1": {
        "text": "Memory route."
      },
      "event3": {
        "text": "That sounds stupid."
      },
      "event5": {
        "text": "Still doing it."
      },
      "event7": {
        "text": "The ridge is warm."
      },
      "event9": {
        "text": "Not sun-warm."
      },
      "event11": {
        "text": "Body-warm."
      },
      "event12": {
        "message": "[EVA IS TRAVERSING]"
      }
    },
    "e16_r04_memory": {
      "event1": {
        "text": "Still here."
      },
      "event3": {
        "text": "I kept the memory stable."
      },
      "event5": {
        "text": "Barely."
      },
      "event7": {
        "text": "But the signal trail collapsed behind me."
      },
      "event9": {
        "text": "I watched the line fold into itself."
      },
      "event11": {
        "text": "Like it was never there."
      },
      "event13": {
        "text": "THE DOOR REMEMBERS WITHOUT SIGNAL."
      }
    },
    "e16_n05_noah": {
      "event1": {
        "text": "I know that structure."
      },
      "event3": {
        "text": "..."
      },
      "event5": {
        "text": "I shouldn't."
      },
      "event7": {
        "text": "It's not in my memories."
      },
      "event9": {
        "text": "It's under them."
      },
      "event11": {
        "text": "Like a basement beneath a dream."
      },
      "event13": {
        "text": "Please tell me that sounded less insane in your head."
      },
      "event15": {
        "text": "It did not."
      },
      "choice0": {
        "text": "NOAH, KEEP GOING."
      },
      "choice1": {
        "text": "HALE, WHY ARE YOU QUIET?"
      }
    },
    "e16_n06_noah_more": {
      "event1": {
        "text": "There's a threshold."
      },
      "event3": {
        "text": "Not a door yet."
      },
      "event5": {
        "text": "A place where the world decides whether it wants to be one room or another."
      },
      "event7": {
        "text": "I remember touching it."
      },
      "event9": {
        "text": "No."
      },
      "event11": {
        "text": "Someone remembers through me."
      }
    },
    "e16_n06_hale": {
      "event1": {
        "text": "Because I know what comes next."
      },
      "event3": {
        "text": "Not enough to stop it."
      },
      "event5": {
        "text": "Enough to hate watching it happen again."
      },
      "event7": {
        "text": "Eva."
      },
      "event9": {
        "text": "Turn around."
      },
      "event11": {
        "text": "Now."
      }
    },
