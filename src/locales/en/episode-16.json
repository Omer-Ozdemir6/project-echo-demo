    "e16_n01": {
      "event1": {
        "text": "I remember this place."
      },
      "event3": {
        "text": "No."
      },
      "event5": {
        "text": "That's wrong."
      },
      "event7": {
        "text": "I've never been here."
      },
      "event9": {
        "text": "So why do I remember it?"
      },
      "event11": {
        "text": "THE DOOR WAS NEVER LOCKED."
      },
      "event12": {
        "text": "ONLY FORGOTTEN."
      },
      "choice0": {
        "text": "EVA, STAY WITH ME."
      },
      "choice1": {
        "text": "DESCRIBE THE MEMORY."
      }
    },
    "e16_n02_ground": {
      "event1": {
        "text": "I'm here."
      },
      "event3": {
        "text": "I think."
      },
      "event5": {
        "text": "Suit pressure normal."
      },
      "event7": {
        "text": "Hands shaking, but normal."
      },
      "event9": {
        "text": "Thank you."
      },
      "event11": {
        "text": "Don't let me drift if I start sounding like her."
      }
    },
    "e16_n02_memory": {
      "event1": {
        "text": "White light."
      },
      "event3": {
        "text": "Not station light."
      },
      "event5": {
        "text": "Warmer."
      },
      "event7": {
        "text": "Like it was under my skin."
      },
      "event9": {
        "text": "A door without a frame."
      },
      "event11": {
        "text": "And someone on the other side breathing my name."
      }
    },
