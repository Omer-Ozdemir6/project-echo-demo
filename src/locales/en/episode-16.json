    "e16_n04_signal": {
      "event1": {
        "text": "Signal route."
      },
      "event3": {
        "text": "Going."
      },
      "event5": {
        "text": "The ground isn't ground."
      },
      "event7": {
        "text": "It flexes under my boots."
      },
      "event9": {
        "text": "No footprints."
      },
      "event11": {
        "text": "Not even mine."
      },
      "event12": {
        "message": "[EVA IS TRAVERSING]"
      }
