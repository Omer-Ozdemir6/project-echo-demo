        "message": "[SIGNAL LOST]",
        "restoreMessage": "[SIGNAL RESTORED]"
      },
      "event2": {
        "text": "Did Hale just save us?"
      },
      "event4": {
        "text": "Or did Omega want us to hear him?"
      },
      "event6": {
        "text": "Both can be true."
      },
      "event8": {
        "text": "Please stop finding the worst third option."
      }
