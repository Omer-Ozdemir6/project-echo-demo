    "doorkeeper_memory_correlation_20": {
      "puzzle0": {
        "title": "DOORKEEPER MEMORY CORRELATION",
        "description": "Match each recovered core trace with the correct conclusion.",
        "submitLabel": "CONFIRM DOORKEEPER TRACE"
      }
    },
    "e20_n01": {
      "event0": {
        "text": "YOU KEEP ASKING WHO OPENED THE DOOR."
      },
      "event2": {
        "text": "YOU DID."
      },
      "event3": {
        "text": "YOU JUST DON'T REMEMBER IT."
      },
      "event5": {
        "text": "That's not funny."
      },
      "event6": {
        "text": "IT WAS NOT A JOKE."
      },
      "choice0": {
        "text": "DEMAND PROOF."
      },
      "choice1": {
        "text": "GROUND THE TEAM FIRST."
      }
    },
    "e20_n02_ground": {
      "event1": {
        "text": "Everybody breathe."
      },
      "event3": {
        "text": "I know that's useless advice inside a haunted memory machine."
      },
      "event5": {
        "text": "Still."
      },
      "event7": {
        "text": "Breathe."
      },
      "event9": {
        "text": "Noah?"
      },
      "event11": {
        "text": "Here."
      },
      "event13": {
        "text": "Hale?"
      },
      "event15": {
        "text": "More or less."
      },
      "event17": {
        "text": "Eva?"
      },
      "event19": {
        "text": "I hate that 'more or less' is the best answer in the room."
      }
    },
    "e20_n02_proof": {
      "event0": {
        "text": "[OPERATOR TRACE REQUEST ACCEPTED]"
      },
      "event2": {
        "text": "PROOF IS A DOOR."
      },
      "event3": {
        "text": "OPEN IT AND IT OPENS YOU."
      }
    },
    "e20_n03_corridor": {
      "event0": {
        "title": "DOORKEEPER ACCESS TUNNEL",
        "caption": "Deep corridor leading toward the remembered core. Geometry responds to operator signal."
      },
      "event2": {
        "text": "That voice again."
      },
      "event4": {
        "text": "It's not just deeper inside the structure."
      },
      "event6": {
        "text": "It's ahead of me."
      },
      "event8": {
        "text": "And behind you."
      },
      "event10": {
        "text": "Operator..."
      },
      "event12": {
        "text": "I think the corridor is using your signal as a map."
      },
      "choice0": {
        "text": "TRACE OPERATOR SIGNAL."
      },
      "choice1": {
        "text": "MASK OPERATOR SIGNAL."
      }
    },
    "e20_n04_signal": {
      "event1": {
        "text": "Tracing your signal."
      },
      "event3": {
        "text": "The walls just changed direction."
      },
      "event5": {
        "text": "No."
      },
      "event7": {
        "text": "Not walls."
      },
      "event9": {
        "text": "Memories pretending to be walls."
      },
      "event11": {
        "text": "Wait."
      },
      "event13": {
        "text": "That's my voice."
      },
      "event15": {
        "text": "No, that's impossible."
      },
      "event17": {
        "text": "I'm hearing myself from somewhere ahead."
      },
      "event19": {
        "text": "And I'm saying things I don't remember saying."
      }
    },
    "e20_n04_mask": {
      "event0": {
        "text": "[OPERATOR SIGNAL MASK ACTIVE]"
      },
      "event2": {
        "text": "Mask is up."
      },
      "event4": {
        "text": "The corridor slowed down."
      },
      "event6": {
        "text": "I don't like that sentence."
      },
      "event8": {
        "text": "Things that slow down can speed up again."
      },
      "event9": {
        "text": "HIDING IS STILL A WAY OF ANSWERING."
      }
    },
    "e20_n05_echo_report": {
      "event0": {
        "title": "MEMORY ECHO REPORT",
        "content": "OMEGA MEMORY RESPONSE DETECTED\nSOURCE: DOORKEEPER ACCESS TUNNEL\nECHO TYPE: ACTIVE RECONSTRUCTION\nSUBJECTS INCLUDED: EVA / NOAH / HALE / OPERATOR\nWARNING: reconstruction is not replaying the past. It is testing a future response.",
        "caption": "Memory echo report confirms the corridor is reconstructing the team and the Operator.",
        "message": "[MEMORY ECHO REPORT ARCHIVED TO DATA BANK]"
      },
      "event2": {
        "text": "Testing a future response."
      },
      "event4": {
        "text": "I liked this more when it was only rewriting the past."
      },
      "choice0": {
        "text": "OBSERVE THE ECHO."
      },
      "choice1": {
        "text": "INTERRUPT THE ECHO."
      }
    },
    "e20_n06_interrupt": {
      "event0": {
        "text": "[ECHO INTERRUPT ATTEMPTED]"
      },
      "event2": {
        "text": "[ECHO RESISTED INTERRUPT]"
      },
      "event4": {
        "text": "It pushed back."
      },
      "event6": {
        "text": "Not like software."
      },
      "event8": {
        "text": "Like a hand on the other side of glass."
      }
    },
    "e20_n06_echo": {
      "event0": {
        "text": "[MEMORY ECHO ACTIVE]"
      },
      "event1": {
        "title": "ARCHIVED MEMORY",
        "caption": "Recovered memory reconstruction. The scene reacts to live speech."
      },
      "event3": {
        "text": "The artifact reacted."
      },
      "event5": {
        "text": "No."
      },
      "event7": {
        "text": "Hale, don't call it artifact."
      },
      "event9": {
        "text": "That's too small for something that knows when we're scared."
      },
      "event11": {
        "text": "He's right."
      },
      "event13": {
        "text": "The room is copying our breathing."
      }
    },
    "e20_n07_noah": {
      "event1": {
        "text": "My head hurts."
      },
      "event3": {
        "text": "Not a headache."
      },
      "event5": {
        "text": "A missing piece ache."
      },
      "event7": {
        "text": "Every memory we recover takes something with it."
      },
      "event9": {
        "text": "I can't remember my mother's face."
      },
      "event11": {
        "text": "I know I had one."
      },
      "event13": {
        "text": "I just can't see her anymore."
      },
      "event15": {
        "text": "Noah..."
      },
      "event17": {
        "text": "Don't make that sound."
      },
      "event19": {
        "text": "If you sound sorry, I get scared faster."
      },
      "choice0": {
        "text": "PROTECT NOAH'S MEMORY."
      },
      "choice1": {
        "text": "USE NOAH AS ANCHOR."
      }
    },
    "e20_n08_protect_noah": {
      "event0": {
        "text": "[NOAH MEMORY SHIELD ACTIVE]"
      },
      "event2": {
        "text": "Thank you."
      },
      "event4": {
        "text": "I know we need answers."
      },
      "event6": {
        "text": "I also know I'm running out of places to keep them."
      }
    },
    "e20_n08_use_noah": {
      "event0": {
        "text": "[NOAH ECHO ANCHOR ACCEPTED]"
      },
      "event2": {
        "text": "Okay."
      },
      "event4": {
        "text": "I can hold it."
      },
      "event6": {
        "text": "No."
      },
      "event8": {
        "text": "That's a lie."
      },
      "event10": {
        "text": "I'm holding it anyway."
      },
      "event12": {
        "text": "Someone write down my mother's face if I find it again."
      }
    },
    "e20_n09_hale_warning": {
      "event1": {
        "text": "Stop listening to it."
      },
      "event3": {
        "text": "That's exactly what it wants."
      },
      "event5": {
        "text": "You think you're investigating Omega."
      },
      "event7": {
        "text": "You're feeding it."
      },
      "event9": {
        "text": "Every answer costs something."
      },
      "event11": {
        "text": "That's how Omega works."
      },
      "event12": {
        "text": "HE REMEMBERS THE PRICE."
      },
      "event13": {
        "text": "HE PAID IT ONCE."
      },
      "choice0": {
        "text": "LISTEN TO HALE."
      },
      "choice1": {
        "text": "KEEP GOING."
      }
    },
    "e20_n10_listen": {
      "event1": {
        "text": "I'm backing up."
      },
      "event3": {
        "text": "I hate that Hale might be right."
      },
      "event5": {
        "text": "I hate it professionally."
      },
      "event6": {
        "text": "[DISTANCE FROM CORE INCREASED]"
      },
      "event8": {
        "text": "The corridor doesn't like that."
      },
      "event10": {
        "text": "It just got colder."
      },
      "event12": {
        "text": "Good."
      },
      "event14": {
        "text": "Cold means it's not getting what it wants."
      }
    },
    "e20_n10_continue": {
      "event1": {
        "text": "No."
      },
      "event3": {
        "text": "We came this far."
      },
      "event5": {
        "text": "If Omega wanted us gone, it would not keep inviting us deeper."
      },
      "event7": {
        "text": "That is exactly how traps work."
      },
      "event8": {
        "text": "[CORE PROXIMITY INCREASED]"
      },
      "event9": {
        "text": "CLOSER."
      },
      "event10": {
        "text": "GOOD."
      }
    },
    "e20_n11_signal_loss": {
