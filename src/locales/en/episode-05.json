{
  "episode_05": {
    "meta": {
      "title": "THE SIX — ECHO DIRECTOR'S CUT V8"
    },
    "e05_n01": {
      "event1": {
        "text": "Okay."
      },
      "event4": {
        "text": "Still here."
      },
      "event6": {
        "text": "Relay pack is blinking again."
      },
      "event9": {
        "text": "Not cute blinking."
      },
      "event11": {
        "text": "Warning blinking."
      },
      "event14": {
        "text": "I'm putting it on."
      },
      "event16": {
        "text": "Ow."
      },
      "event18": {
        "text": "No. Fine."
      },
      "event20": {
        "text": "Less fine."
      },
      "backgroundEvent21": {
        "text": "If I go quiet, both hands are busy. Or something is close. Terrible range."
      },
      "event22": {
        "message": "[MAYA IS SECURING THE RELAY PACK]"
      }
    },
    "e05_r01_relay_ready": {
      "event1": {
        "text": "Pack's on."
      },
      "event4": {
        "text": "Heavy."
      },
      "event6": {
        "text": "Feels like carrying a second bad idea."
      },
      "event9": {
        "text": "Lower access spine ahead."
      },
      "event11": {
        "text": "Two lights still working."
      },
      "event13": {
        "text": "One flickers when I breathe."
      },
      "event16": {
        "text": "Life support is below."
      },
      "event18": {
        "text": "If the manifest lied, the air system might not."
      },
      "choice0": {
        "text": "PULL THE MANIFEST WHILE MOVING."
      },
      "choice1": {
        "text": "ASK WHO THE CREW WERE."
      }
    },
    "e05_n02_memory_walk": {
      "event1": {
        "text": "Oh."
      },
      "event4": {
        "text": "Mean question."
      },
      "event6": {
        "text": "Useful mean."
      },
      "backgroundEvent7": {
        "text": "Cable. One second. Stepping over it."
      },
      "event9": {
        "text": "Grant checked every exit twice."
      },
      "event11": {
        "text": "Rivera yelled at broken panels."
      },
      "event13": {
        "text": "They usually listened."
      },
      "event15": {
        "text": "Owens laughed quietly."
      },
      "event18": {
        "text": "Hale corrected everything."
      },
      "event20": {
        "text": "Even silence, somehow."
      },
      "event23": {
        "text": "Sorry."
      },
      "event25": {
        "text": "Went somewhere else for a second."
      },
      "event27": {
        "text": "Back."
      }
    },
    "e05_n02_manifest_moving": {
      "event0": {
        "title": "CREW MANIFEST",
        "content": "01 Ethan Hale\n02 Maya Chen\n03 Grant Walker\n04 Rivera Torres\n05 Owen Park\n06 Sarah Owens",
        "caption": "Official ECHO crew manifest. Six listed crew members.",
        "message": "[CREW MANIFEST ARCHIVED TO DATA BANK]"
      },
      "event2": {
        "text": "Six names."
      },
      "event4": {
        "text": "Still six."
      },
      "event7": {
        "text": "Very clean."
      },
      "event9": {
        "text": "I don't trust clean anymore."
      },
      "backgroundEvent10": {
        "text": "Wall clicked behind me. I stopped. It stopped too."
      },
      "event12": {
        "text": "Life support is below."
      },
      "event14": {
        "text": "Hale's control route is closer."
      },
      "choice0": {
        "text": "ASK WHAT HALE CONTROLLED."
      },
      "choice1": {
        "text": "SEND MAYA TO LIFE SUPPORT."
      }
    },
    "e05_n03_hale_control": {
      "event1": {
        "text": "Doors."
      },
      "event3": {
        "text": "Power."
      },
      "event5": {
        "text": "Pressure."
      },
      "event8": {
        "text": "Anything that could kill you with paperwork attached."
      },
      "event10": {
        "text": "He was good."
      },
      "event13": {
        "text": "That's the hard part."
      },
      "event15": {
        "text": "Useful people can hide inside useful work."
      }
    },
    "e05_n03_route_choice": {
      "event1": {
        "text": "Stairwell's open."
      },
      "event3": {
        "text": "Not welcoming."
      },
      "event6": {
        "text": "Main corridor is faster."
      },
      "event8": {
        "text": "Maintenance crawl is quieter."
      },
      "event11": {
        "text": "Fast means exposed."
      },
      "event13": {
        "text": "Quiet means tight."
      },
      "event15": {
        "text": "Pick the bad one."
      },
      "choice0": {
        "text": "TAKE THE MAIN CORRIDOR."
      },
      "choice1": {
        "text": "TAKE THE MAINTENANCE CRAWL."
      }
    },
    "e05_n04_main_corridor": {
      "event1": {
        "text": "Main corridor."
      },
      "event4": {
        "text": "Head down."
      },
      "event6": {
        "text": "Not looking into rooms."
      },
      "backgroundEvent7": {
        "text": "I started walking."
      },
      "backgroundEvent8": {
        "text": "A second set of footsteps started with me."
      },
      "backgroundEvent9": {
        "text": "I stopped."
      },
      "backgroundEvent10": {
        "text": "They stopped too."
      },
      "event11": {
        "message": "[MAYA IS MOVING THROUGH MAIN CORRIDOR]"
      }
    },
    "e05_n04_maintenance_crawl": {
      "event1": {
        "text": "Maintenance crawl."
      },
      "event4": {
        "text": "Tiny tunnel."
      },
      "event6": {
        "text": "Cables everywhere."
      },
      "event8": {
        "text": "Helmet already scraped."
      },
      "backgroundEvent9": {
        "text": "Something touched the back of my neck. Cable. It was a cable."
      },
      "backgroundEvent10": {
        "text": "Found a tag under the tray. Not touching it yet. Need both hands."
      },
      "event11": {
        "message": "[MAYA IS CRAWLING THROUGH MAINTENANCE]"
      }
    },
    "e05_r04_main_corridor": {
      "event2": {
        "text": "At the hatch."
      },
      "event5": {
        "text": "I ran."
      },
      "event7": {
        "text": "Not gracefully."
      },
      "event10": {
        "text": "Footsteps stayed behind me."
      },
      "event12": {
        "text": "Not close."
      },
      "event14": {
        "text": "Close enough."
      }
    },
    "e05_r04_maintenance": {
      "event1": {
        "text": "Out."
      },
      "event3": {
        "text": "Don't ask how."
      },
      "event6": {
        "text": "The tag was Grant's."
      },
      "event7": {
        "title": "GRANT'S SECURITY TAG",
        "content": "DAMAGED ID TAG\nNAME: GRANT WALKER\nACCESS: SECURITY / LOWER SPINE\nSTATUS: OFFLINE\nNOTE: Impact scoring along edge.",
        "caption": "Maya recovered Grant Walker's damaged security tag from the maintenance crawl.",
        "message": "[GRANT'S SECURITY TAG ARCHIVED TO DATA BANK]"
      },
      "event9": {
        "text": "He'd hate this."
      },
      "event11": {
        "text": "Me finding him in a vent."
      },
      "event14": {
        "text": "I'm angry so I don't get sad."
      }
    },
    "e05_n05_life_support_hatch": {
      "event1": {
        "text": "Life-support hatch."
      },
      "event3": {
        "text": "Panel's half dead."
      },
      "event5": {
        "text": "Manual latch is still there."
      },
      "event8": {
        "text": "I can force it."
      },
      "event10": {
        "text": "Or check the seam first."
      },
      "event12": {
        "text": "Please choose the boring smart thing."
      },
      "choice0": {
        "text": "FORCE THE HATCH OPEN."
      },
      "choice1": {
        "text": "CHECK THE PRESSURE SEAM."
      }
    },
    "e05_n06_force_hatch": {
      "event1": {
        "text": "Forcing it."
      },
      "event3": {
        "text": "Left hand on latch."
      },
      "event5": {
        "text": "Right hand braced."
      },
      "event8": {
        "text": "This is going to be loud."
      },
      "event9": {
        "message": "[MAYA IS FORCING THE HATCH]"
      }
    },
    "e05_n06_scan_hatch": {
      "event1": {
        "text": "Reader's on."
      },
      "event4": {
        "text": "Seam's hot."
      },
      "event6": {
        "text": "No. Wait."
      },
      "event8": {
        "text": "Pressurized."
      },
      "event11": {
        "text": "You just saved my hand."
      },
      "event12": {
        "message": "[MAYA IS VENTING THE HATCH]"
      }
    },
    "e05_r06_force_return": {
      "event2": {
        "text": "Open."
      },
      "event5": {
        "text": "Ow."
      },
      "event7": {
        "text": "Nope."
      },
      "event9": {
        "text": "Bigger ow."
      },
      "event11": {
        "text": "Pressure kicked the latch back."
      },
      "event13": {
        "text": "Glove's red."
      },
      "event16": {
        "text": "Don't apologize."
      },
      "event18": {
        "text": "I know why we did it."
      },
      "event20": {
        "text": "I'm still mad."
      }
    },
    "e05_r06_scan_return": {
      "event1": {
        "text": "Hatch opened."
      },
      "event3": {
        "text": "Quietly."
      },
      "event6": {
        "text": "I love quietly."
      },
      "event8": {
        "text": "Pressure was trapped behind the seam."
      },
      "event10": {
        "text": "Good call."
      }
    },
    "e05_n07_life_support_core": {
      "event1": {
        "text": "Inside."
      },
      "event3": {
        "text": "Colder than the corridor."
      },
      "event6": {
        "text": "Air system is awake."
      },
      "event8": {
        "text": "Barely."
      },
      "event9": {
        "title": "LIFE SUPPORT ALLOCATION",
        "content": "ECHO LIFE SUPPORT SNAPSHOT\n\nAssigned crew capacity: 6\nActive biometric loads before blackout: 7\nOxygen adjustment event: automatic\nUnauthorized load marker: removed from index",
        "caption": "Life support record showing seven biometric loads against six assigned crew.",
        "message": "[LIFE SUPPORT ALLOCATION ARCHIVED TO DATA BANK]"
      },
      "event12": {
        "text": "Seven."
      },
      "event15": {
        "text": "No."
      },
      "event17": {
        "text": "I checked it again."
      },
      "event19": {
        "text": "Still seven."
      },
      "event22": {
        "text": "The manifest counted names."
      },
      "event24": {
        "text": "This counted breathing."
      },
      "event27": {
        "text": "Be careful with the next question."
      },
      "choice0": {
        "text": "SEND MAYA TO EVA STORAGE."
      },
      "choice1": {
        "text": "ASK IF SHE KNEW ABOUT SEVEN."
      }
    },
    "e05_n08_maya_confronted": {
      "event1": {
        "text": "Wow."
      },
      "event4": {
        "text": "Right into the soft part."
      },
      "event6": {
        "text": "No."
      },
      "event8": {
        "text": "I didn't know."
      },
      "event11": {
        "text": "And yes, I know how that sounds."
      },
      "event13": {
        "text": "Only living person in the room."
      },
      "event15": {
        "text": "Convenient."
      },
      "event18": {
        "text": "But now that you made me look at the gap..."
      },
      "event20": {
        "text": "I can feel it."
      },
      "event22": {
        "text": "Like a door in my head got painted over."
      },
      "event25": {
        "text": "I hate you a little for asking."
      },
      "event27": {
        "text": "Keep asking anyway."
      }
    },
    "e05_n08_eva_route": {
      "event1": {
        "text": "EVA storage is close."
      },
      "event3": {
        "text": "Close is suspicious now."
      },
      "event6": {
        "text": "Suit prep is direct."
      },
      "event8": {
        "text": "Decon is longer."
      },
      "event10": {
        "text": "Suit prep means racks."
      },
      "event13": {
        "text": "I know what's probably still hanging there."
      },
      "choice0": {
        "text": "CUT THROUGH SUIT PREP."
      },
      "choice1": {
        "text": "GO THROUGH DECON."
      }
    },
    "e05_n09_suit_prep": {
      "event1": {
        "text": "Suit prep."
      },
      "event3": {
        "text": "Direct route."
      },
      "event5": {
        "text": "Bad memories on hooks."
      },
      "backgroundEvent6": {
        "text": "I am not looking at the name tags."
      },
      "backgroundEvent7": {
        "text": "One suit is missing."
      },
      "backgroundEvent8": {
        "text": "Not damaged. Not moved. Missing."
      },
      "event9": {
        "message": "[MAYA IS CROSSING SUIT PREP]"
      }
    },
    "e05_n09_decon": {
      "event1": {
        "text": "Decon."
      },
      "event3": {
        "text": "Long route."
      },
      "event5": {
        "text": "More breathing."
      },
      "event7": {
        "text": "Less seeing."
      },
      "backgroundEvent8": {
        "text": "Blue. White. Blue. White. Lights still cycling like cleaning matters."
      },
      "backgroundEvent9": {
        "text": "CLEAN DOES NOT MEAN EMPTY"
      },
      "event10": {
        "message": "[MAYA IS MOVING THROUGH DECON]"
      }
    },
    "e05_r09_suit_prep": {
      "event1": {
        "text": "Through."
      },
      "event4": {
        "text": "Kicked a helmet."
      },
      "event6": {
        "text": "Empty."
      },
      "event8": {
        "text": "Cracked visor."
      },
      "event11": {
        "text": "The missing suit had a shadow behind it."
      },
      "event13": {
        "text": "Dust outline."
      },
      "event15": {
        "text": "Someone took it fast."
      }
    },
    "e05_r09_decon": {
      "event1": {
        "text": "Made it."
      },
      "event3": {
        "text": "Room smelled like metal and old antiseptic."
      },
      "event6": {
        "text": "I used to hate that smell."
      },
      "event8": {
        "text": "Now it means the room stayed a room."
      },
      "event11": {
        "text": "Oxygen dipped."
      },
      "event13": {
        "text": "Still worth it."
      }
    },
    "e05_n10_eva_registry": {
      "event1": {
        "text": "Registry panel."
      },
      "event3": {
        "text": "Screen is cracked."
      },
      "event5": {
        "text": "Still accepts touch."
      },
      "event6": {
        "title": "EVA SUIT REGISTRY",
        "content": "EVA STORAGE REGISTRY\n\nSlot 01 — ETHAN HALE\nSlot 02 — MAYA CHEN\nSlot 03 — GRANT WALKER\nSlot 04 — RIVERA TORRES\nSlot 05 — OWEN PARK\nSlot 06 — SARAH OWENS\nSlot 07 — [IDENTITY ERASED]\n\nSlot 07 status: suit removed before blackout.",
        "caption": "Recovered EVA registry showing seven suit slots and one erased identity.",
        "message": "[EVA SUIT REGISTRY ARCHIVED TO DATA BANK]"
      },
      "event8": {
        "text": "Seven suit slots."
      },
      "event10": {
        "text": "Six names."
      },
      "event13": {
        "text": "No puzzle needed."
      },
      "event15": {
        "text": "I hate the math by itself."
      },
      "event16": {
        "title": "MANIFEST_V2",
        "content": "01 Ethan Hale\n02 Maya Chen\n03 Grant Walker\n04 Rivera Torres\n05 Owen Park\n06 Sarah Owens\n07 █████████\n\nLayer status: identity erased, not redacted.",
        "caption": "Alternate manifest layer. Seventh entry erased rather than redacted.",
        "message": "[MANIFEST_V2 ARCHIVED TO DATA BANK]"
      },
      "event18": {
        "text": "Erased."
      },
      "event20": {
        "text": "Not redacted."
      },
      "event22": {
        "text": "Redacted hides a name."
      },
      "event24": {
        "text": "Erased removes the place where it lived."
      },
      "choice0": {
        "text": "ASK WHERE SHE SAW THE NAME."
      },
      "choice1": {
        "text": "ASK WHY SOMEONE REMOVED IT."
      }
    },
    "e05_n11_removed": {
      "event1": {
        "text": "Because missing can be found."
      },
      "event4": {
        "text": "Removed is different."
      },
      "event6": {
        "text": "NOT MISSING"
      },
      "event7": {
        "text": "REMOVED"
      },
      "event8": {
        "text": "ASK WHO SIGNED THE ERASE"
      },
      "event10": {
        "text": "I didn't say that."
      },
      "event12": {
        "text": "I didn't type that."
      }
    },
    "e05_n11_break": {
      "backgroundEvent0": {
        "text": "MISSING"
      },
      "backgroundEvent1": {
        "text": "NOT MISSING"
      },
      "backgroundEvent2": {
        "text": "REMOVED"
      },
      "event4": {
        "text": "No."
      },
      "event7": {
        "text": "I don't know the name."
      },
      "event9": {
        "text": "That's not right."
      },
      "event11": {
        "text": "I don't know that I don't know it."
      },
      "event14": {
        "text": "Does that make sense?"
      },
      "event16": {
        "text": "Don't answer."
      },
      "event18": {
        "text": "It doesn't."
      },
      "choice0": {
        "text": "ASK WHERE SHE SAW IT."
      },
      "choice1": {
        "text": "GROUND MAYA FIRST."
      }
    },
    "e05_n12_ground_maya": {
      "event1": {
        "text": "Okay."
      },
      "event3": {
        "text": "Feet on floor."
      },
      "event5": {
        "text": "Left hand hurts if I move it."
      },
      "event7": {
        "text": "Air tastes like metal."
      },
      "event10": {
        "text": "Your voice is still there."
      },
      "event12": {
        "text": "That helps."
      }
    },
    "e05_n12_accuse_maya": {
      "event1": {
        "text": "You keep cutting at it."
      },
      "event4": {
        "text": "Fine."
      },
      "event6": {
        "text": "Suit prep."
      },
      "event8": {
        "text": "No. Not there."
      },
      "event10": {
        "text": "A door."
      },
      "event12": {
        "text": "White paint over a number."
      },
      "event15": {
        "text": "I saw the shape of a name."
      },
      "event17": {
        "text": "Not the name."
      },
      "event20": {
        "text": "Keep that question."
      },
      "event22": {
        "text": "But if I die while you decide whether I'm guilty, I am haunting your interface."
      }
    },
    "e05_n12_first_voice": {
      "event1": {
        "text": "FIRST CONTACT"
      },
      "event2": {
        "text": "FIRST FILE"
      },
      "event3": {
        "text": "FIRST LIE"
      },
      "event4": {
        "message": "[SIGNAL LOST]",
        "restoreMessage": "[SIGNAL RESTORED]"
      },
      "event5": {
        "text": "NOT HALE"
      },
      "event6": {
        "text": "BEFORE HALE"
      },
      "event7": {
        "text": "ETHAN HALE WAS NOT THE FIRST VOICE."
      },
      "event10": {
        "text": "Operator..."
      },
      "event12": {
        "text": "Something moved in the suit rack."
      },
      "event15": {
        "text": "No."
      },
      "event17": {
        "text": "Not moved."
      },
      "event19": {
        "text": "Stood up."
      },
      "event20": {
        "text": "ASK WHO WORE SLOT SEVEN"
      },
      "event22": {
        "text": "I need to run."
      },
      "choice0": {
        "text": "SEARCH FIRST CONTACT RECORDS."
      },
      "choice1": {
        "text": "ASK MAYA ABOUT THE FIRST VOICE."
      }
    }
  }
}
