{
  "episode_44": {
    "meta": {
      "episode0": {
        "title": "THE CHOICE",
        "description": "The first irreversible decision."
      }
    },
    "e44_n01": {
      "event1": {
        "text": "I abandoned Observer."
      },
      "event2": {
        "text": "Hale?"
      },
      "event3": {
        "text": "No."
      },
      "event4": {
        "text": "Not Hale."
      },
      "event5": {
        "text": "[SIGNAL SOURCE IDENTIFIED]"
      },
      "event6": {
        "title": "SURVIVING ARCHIVE SIGNAL",
        "content": "SOURCE: UNKNOWN\nSTATUS: ACTIVE\nLOCATION: ARCHIVE FACILITY\nSIGNAL INTEGRITY: UNSTABLE"
      },
      "event7": {
        "text": "The source is real."
      },
      "event8": {
        "text": "There is a surviving archive."
      },
      "event9": {
        "text": "And you want us to walk into it."
      },
      "event10": {
        "text": "Just once, I would like the haunted space archive to stay closed."
      },
      "event11": {
        "text": "Someone must go there."
      }
    },
    "e44_choice": {
      "event0": {
        "text": "[IRREVERSIBLE DECISION REQUIRED]"
      },
      "event1": {
        "text": "Choose who enters the archive facility."
      },
      "event2": {
        "text": "Eva is faster."
      },
      "event3": {
        "text": "I'm more familiar with the old archive systems."
      },
      "event4": {
        "text": "That sounded almost like a compliment."
      },
      "event5": {
        "text": "Don't get used to it."
      },
      "event6": {
        "text": "For the record, I vote for sending nobody."
      },
      "event7": {
        "text": "Waiting is also a choice."
      },
      "event8": {
        "text": "It usually kills someone quieter."
      },
      "choice0": {
        "text": "SEND EVA."
      },
      "choice1": {
        "text": "SEND MARA."
      }
    },
    "e44_eva_path": {
      "event1": {
        "text": "You picked me?"
      },
      "event2": {
        "text": "Fine."
      },
      "event3": {
        "text": "Let's see if that was bravery or terrible judgment."
      },
      "event4": {
        "text": "Those are often the same thing."
      },
      "event5": {
        "text": "[EVA ENTERING ARCHIVE FACILITY]"
      }
    },
    "e44_eva_waiting": {
      "event0": {
        "text": "Eva is exploring the archive facility..."
      },
      "event1": {
        "text": "Structural stability decreasing."
      }
    },
    "e44_eva_result": {
      "event1": {
        "text": "Something's wrong."
      },
      "event2": {
        "text": "[FLOOR COLLAPSE DETECTED]"
      },
      "event3": {
        "text": "AHH—!"
      },
      "event4": {
        "text": "[EVA HEALTH -35]"
      },
      "event5": {
        "text": "Eva!"
      },
      "event7": {
        "text": "I'm alive."
      },
      "event8": {
        "text": "Bad news: I think my ribs have filed a complaint."
      },
      "event9": {
        "text": "But she reached the lower archive."
      },
      "event10": {
        "text": "At a cost."
      }
    },
    "e44_mara_path": {
      "event1": {
        "text": "Understood."
      },
      "event2": {
        "text": "You don't have to sound that calm."
      },
      "event3": {
        "text": "I am not calm."
      },
      "event4": {
        "text": "I'm efficient."
      },
      "event5": {
        "text": "That is the most terrifying sentence anyone has said today."
      },
      "event6": {
        "text": "[MARA ENTERING ARCHIVE FACILITY]"
      }
    },
    "e44_mara_waiting": {
      "event0": {
        "text": "Mara is exploring the archive facility..."
      },
      "event1": {
        "text": "Archive integrity decreasing."
      }
    },
    "e44_mara_result": {
      "event0": {
        "text": "Archive reached."
      },
      "event1": {
        "text": "The Evelyn records are gone."
      },
      "event2": {
        "text": "[KNOWLEDGE LOST +1]"
      },
      "event3": {
        "text": "Gone?"
      },
      "event4": {
        "text": "Deleted."
      },
      "event5": {
        "text": "Recently."
      },
      "event6": {
        "text": "Then the archive source protected itself."
      },
      "event7": {
        "text": "Or someone got there first."
      }
    },
    "episode_end": {
      "event0": {
        "text": "[PERMANENT CONSEQUENCE RECORDED]"
      },
      "event1": {
        "text": "Eva reached the lower archive, but was injured during entry."
      },
      "event2": {
        "text": "Mara reached the archive safely, but the Evelyn records were lost."
      },
      "event3": {
        "text": "Now you understand."
      },
      "event4": {
        "text": "A choice is only real when it can hurt."
      }
    }
  }
}
