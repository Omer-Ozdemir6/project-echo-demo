      "event6": {
        "text": "Every one of them says that."
      },
      "event7": {
        "text": "Every scientist."
      },
      "event8": {
        "text": "We were trying to save people."
      },
      "event9": {
        "text": "You didn't save them."
      },
      "event10": {
        "text": "You archived them."
      }
    },
