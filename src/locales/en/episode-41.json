    "e41_n09": {
      "event1": {
        "text": "I killed her."
      },
      "event2": {
        "text": "Noah, no."
      },
      "event3": {
        "text": "I built a machine to save her."
      },
      "event4": {
        "text": "And the best it could do was turn her into a wound that keeps answering."
      },
      "event5": {
        "text": "Now you understand."
