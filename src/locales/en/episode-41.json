      "event6": {
        "text": "The question isn't: \"Is Evelyn alive?\""
      },
      "event8": {
        "text": "The question is: \"How much of Evelyn survived?\""
      }
    },
    "e41_n02": {
      "event0": {
        "title": "RECONSTRUCTION PROTOCOL",
        "content": "BIOLOGICAL STATUS: DECEASED\nMEMORY STATUS: 87%\nPERSONALITY STATUS: 91%\nRECONSTRUCTION POSSIBLE"
